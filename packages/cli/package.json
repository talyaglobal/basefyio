{
  "name": "kolaybase-cli",
  "version": "0.1.0",
  "description": "Kolaybase CLI — manage your backend projects from the terminal",
  "type": "module",
  "bin": {
    "kb": "./dist/index.js",
    "kolaybase": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
