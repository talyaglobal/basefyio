  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.1",
    "inquirer": "^9.2.0",
    "axios": "^1.7.0",
    "dotenv": "^16.4.0",
    "pg": "^8.12.0",
    "execa": "^8.0.1",
    "conf": "^12.0.0",
    "boxen": "^7.1.0",
    "table": "^6.8.0"
  },
  "devDependencies": {
