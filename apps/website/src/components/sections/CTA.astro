---
interface Props {
  variant?: 'default' | 'centered' | 'split';
  title: string;
  description?: string;
  primaryCta?: {
    text: string;
    href: string;
  };
  secondaryCta?: {
    text: string;
    href: string;
  };
}

const {
  variant = 'default',
  title,
  description,
  primaryCta,
  secondaryCta,
} = Astro.props;
---

{variant === 'default' && (
  <section class="section">
    <div class="container">
      <div class="relative overflow-hidden rounded-2xl bg-primary p-8 md:p-12 lg:p-16">
        <!-- Background pattern -->
        <div class="absolute inset-0 opacity-10">
          <svg class="h-full w-full" viewBox="0 0 100 100" preserveAspectRatio="none">
            <defs>
              <pattern id="grid" width="10" height="10" patternUnits="userSpaceOnUse">
                <path d="M 10 0 L 0 0 0 10" fill="none" stroke="white" stroke-width="0.5" />
              </pattern>
            </defs>
            <rect width="100" height="100" fill="url(#grid)" />
          </svg>
        </div>

        <div class="relative max-w-2xl">
          <h2 class="text-h2 text-white">{title}</h2>
          {description && (
            <p class="mt-4 text-body text-white/80">{description}</p>
          )}
          
          {(primaryCta || secondaryCta) && (
            <div class="flex flex-col sm:flex-row items-start gap-4 mt-8">
              {primaryCta && (
                <a
                  href={primaryCta.href}
                  class="inline-flex items-center justify-center h-12 px-6 rounded-md bg-white text-primary font-medium hover:bg-white/90 transition-all duration-150 shadow-subtle"
                >
                  {primaryCta.text}
                  <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </a>
              )}
              {secondaryCta && (
                <a
                  href={secondaryCta.href}
                  class="inline-flex items-center justify-center h-12 px-6 rounded-md border border-white/30 text-white font-medium hover:bg-white/10 transition-all duration-150"
                >
                  {secondaryCta.text}
                </a>
              )}
            </div>
          )}
        </div>
      </div>
    </div>
  </section>
)}

{variant === 'centered' && (
  <section class="section">
    <div class="container">
      <div class="relative overflow-hidden rounded-2xl bg-surface border border-border p-8 md:p-12 lg:p-16">
        <div class="absolute inset-0 bg-gradient-radial from-primary/5 via-transparent to-transparent" />
        
        <div class="relative max-w-2xl mx-auto text-center">
          <h2 class="text-h2 text-text">{title}</h2>
          {description && (
            <p class="mt-4 text-body text-text-secondary">{description}</p>
          )}
          
          {(primaryCta || secondaryCta) && (
            <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mt-8">
              {primaryCta && (
                <a
                  href={primaryCta.href}
                  class="inline-flex items-center justify-center h-12 px-6 rounded-md bg-primary text-primary-foreground font-medium hover:bg-primary-hover transition-all duration-150 shadow-subtle hover:shadow-soft"
                >
                  {primaryCta.text}
                  <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </a>
              )}
              {secondaryCta && (
                <a
                  href={secondaryCta.href}
                  class="inline-flex items-center justify-center h-12 px-6 rounded-md border border-border text-text font-medium hover:bg-surface-2 hover:border-border-hover transition-all duration-150"
                >
                  {secondaryCta.text}
                </a>
              )}
            </div>
          )}
        </div>
      </div>
    </div>
  </section>
)}

{variant === 'split' && (
  <section class="section bg-surface border-y border-border">
    <div class="container">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-8">
        <div class="max-w-xl">
          <h2 class="text-h2 text-text">{title}</h2>
          {description && (
            <p class="mt-4 text-body text-text-secondary">{description}</p>
          )}
        </div>
        
        {(primaryCta || secondaryCta) && (
          <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 shrink-0">
            {primaryCta && (
              <a
                href={primaryCta.href}
                class="inline-flex items-center justify-center h-12 px-6 rounded-md bg-primary text-primary-foreground font-medium hover:bg-primary-hover transition-all duration-150 shadow-subtle hover:shadow-soft"
              >
                {primaryCta.text}
                <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
            )}
            {secondaryCta && (
              <a
                href={secondaryCta.href}
                class="inline-flex items-center justify-center h-12 px-6 rounded-md border border-border text-text font-medium hover:bg-bg hover:border-border-hover transition-all duration-150"
              >
                {secondaryCta.text}
              </a>
            )}
          </div>
        )}
      </div>
    </div>
  </section>
)}
