---
import { PricingPlansIsland } from '../billing/PricingPlansIsland';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Transparent pricing',
  description =
    'Plans are loaded live from the platform API. Pick a tier and continue to signup. Prices are shown in USD per month excluding taxes and billed through Stripe.',
} = Astro.props;
---

<section class="section" id="pricing-section">
  <div class="container">
    <div class="max-w-3xl mx-auto text-center mb-12">
      <h2 class="text-h2 text-text">{title}</h2>
      <p class="mt-4 text-body text-text-secondary">{description}</p>
    </div>

    <PricingPlansIsland client:load sectionId="pricing-plans-grid" />

    <div class="text-center mt-12">
      <p class="text-body-sm text-muted">
        Have questions?{' '}
        <a href="/contact" class="text-primary hover:text-primary-hover underline underline-offset-2">
          Contact us
        </a>
        {' '}
        or read the{' '}
        <a href="#faq" class="text-primary hover:text-primary-hover underline underline-offset-2"> FAQ </a>
        .
      </p>
    </div>
  </div>
</section>
