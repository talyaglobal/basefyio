---
import AntigravityIsland from '../animations/AntigravityIsland.astro';

interface Props {
  variant?: 'default' | 'gradient' | 'split' | 'antigravity';
  badge?: string;
  title: string;
  titleHighlight?: string;
  description: string;
  primaryCta?: {
    text: string;
    href: string;
  };
  secondaryCta?: {
    text: string;
    href: string;
  };
  image?: {
    src: string;
    alt: string;
  };
  stats?: Array<{
    value: string;
    label: string;
  }>;
  /** Antigravity animation options (only for variant='antigravity') */
  antigravityOptions?: {
    count?: number;
    color?: string;
    particleShape?: 'capsule' | 'sphere' | 'box' | 'tetrahedron';
  };
}

const {
  variant = 'gradient',
  badge,
  title,
  titleHighlight,
  description,
  primaryCta,
  secondaryCta,
  image,
  stats,
  antigravityOptions = {},
} = Astro.props;
---

{variant === 'gradient' && (
  <section class="relative overflow-hidden">
    <!-- Background gradient -->
    <div class="absolute inset-0 bg-gradient-radial from-primary/5 via-transparent to-transparent" />
    <div class="absolute inset-0 noise-overlay" />
    
    <div class="container relative">
      <div class="py-24 md:py-32 lg:py-40">
        <div class="max-w-3xl mx-auto text-center">
          {badge && (
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary-muted text-primary text-small font-medium mb-6 animate-fade-in">
              <span class="w-1.5 h-1.5 rounded-full bg-primary animate-pulse" />
              {badge}
            </div>
          )}
          
          <h1 class="text-display text-text text-balance animate-fade-in animation-delay-100">
            {title}
            {titleHighlight && (
              <span class="text-gradient"> {titleHighlight}</span>
            )}
          </h1>
          
          <p class="mt-6 text-body text-text-secondary max-w-2xl mx-auto text-balance animate-fade-in animation-delay-200">
            {description}
          </p>
          
          {(primaryCta || secondaryCta) && (
            <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mt-10 animate-fade-in animation-delay-300">
              {primaryCta && (
                <a
                  href={primaryCta.href}
                  class="inline-flex items-center justify-center h-12 px-6 rounded-md bg-primary text-primary-foreground font-medium hover:bg-primary-hover transition-all duration-150 shadow-subtle hover:shadow-soft active:scale-[0.98]"
                >
                  {primaryCta.text}
                  <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </a>
              )}
              {secondaryCta && (
                <a
                  href={secondaryCta.href}
                  class="inline-flex items-center justify-center h-12 px-6 rounded-md border border-border text-text font-medium hover:bg-surface hover:border-border-hover transition-all duration-150"
                >
                  {secondaryCta.text}
                </a>
              )}
            </div>
          )}
          
          {stats && stats.length > 0 && (
            <div class="flex flex-wrap items-center justify-center gap-8 md:gap-12 mt-16 pt-8 border-t border-border animate-fade-in animation-delay-400">
              {stats.map((stat) => (
                <div class="text-center">
                  <div class="text-h2 text-text font-bold">{stat.value}</div>
                  <div class="text-body-sm text-muted mt-1">{stat.label}</div>
                </div>
              ))}
            </div>
          )}
        </div>
        
        {image && (
          <div class="mt-16 md:mt-20 animate-fade-in animation-delay-500">
            <div class="relative mx-auto max-w-5xl">
              <div class="absolute -inset-4 bg-gradient-to-r from-primary/20 via-primary/10 to-primary/20 rounded-2xl blur-2xl opacity-50" />
              <img
                src={image.src}
                alt={image.alt}
                class="relative rounded-xl border border-border shadow-medium w-full"
                loading="eager"
              />
            </div>
          </div>
        )}
      </div>
    </div>
  </section>
)}

{variant === 'split' && (
  <section class="relative overflow-hidden">
    <div class="container">
      <div class="py-24 md:py-32">
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
          <!-- Content -->
          <div class="order-2 lg:order-1">
            {badge && (
              <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary-muted text-primary text-small font-medium mb-6">
                <span class="w-1.5 h-1.5 rounded-full bg-primary animate-pulse" />
                {badge}
              </div>
            )}
            
            <h1 class="text-h1 md:text-display text-text text-balance">
              {title}
              {titleHighlight && (
                <span class="text-gradient"> {titleHighlight}</span>
              )}
            </h1>
            
            <p class="mt-6 text-body text-text-secondary max-w-xl">
              {description}
            </p>
            
            {(primaryCta || secondaryCta) && (
              <div class="flex flex-col sm:flex-row items-start gap-4 mt-10">
                {primaryCta && (
                  <a
                    href={primaryCta.href}
                    class="inline-flex items-center justify-center h-12 px-6 rounded-md bg-primary text-primary-foreground font-medium hover:bg-primary-hover transition-all duration-150 shadow-subtle hover:shadow-soft active:scale-[0.98]"
                  >
                    {primaryCta.text}
                    <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                    </svg>
                  </a>
                )}
                {secondaryCta && (
                  <a
                    href={secondaryCta.href}
                    class="inline-flex items-center justify-center h-12 px-6 rounded-md border border-border text-text font-medium hover:bg-surface hover:border-border-hover transition-all duration-150"
                  >
                    {secondaryCta.text}
                  </a>
                )}
              </div>
            )}
            
            {stats && stats.length > 0 && (
              <div class="flex flex-wrap gap-8 mt-12 pt-8 border-t border-border">
                {stats.map((stat) => (
                  <div>
                    <div class="text-h3 text-text font-bold">{stat.value}</div>
                    <div class="text-body-sm text-muted mt-1">{stat.label}</div>
                  </div>
                ))}
              </div>
            )}
          </div>
          
          <!-- Image -->
          <div class="order-1 lg:order-2">
            {image && (
              <div class="relative">
                <div class="absolute -inset-4 bg-gradient-to-r from-primary/20 via-primary/10 to-primary/20 rounded-2xl blur-2xl opacity-50" />
                <img
                  src={image.src}
                  alt={image.alt}
                  class="relative rounded-xl border border-border shadow-medium w-full"
                  loading="eager"
                />
              </div>
            )}
          </div>
        </div>
      </div>
    </div>
  </section>
)}

{variant === 'default' && (
  <section class="relative">
    <div class="container">
      <div class="py-24 md:py-32">
        <div class="max-w-3xl">
          {badge && (
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary-muted text-primary text-small font-medium mb-6">
              <span class="w-1.5 h-1.5 rounded-full bg-primary animate-pulse" />
              {badge}
            </div>
          )}
          
          <h1 class="text-h1 md:text-display text-text text-balance">
            {title}
            {titleHighlight && (
              <span class="text-gradient"> {titleHighlight}</span>
            )}
          </h1>
          
          <p class="mt-6 text-body text-text-secondary max-w-2xl">
            {description}
          </p>
          
          {(primaryCta || secondaryCta) && (
            <div class="flex flex-col sm:flex-row items-start gap-4 mt-10">
              {primaryCta && (
                <a
                  href={primaryCta.href}
                  class="inline-flex items-center justify-center h-12 px-6 rounded-md bg-primary text-primary-foreground font-medium hover:bg-primary-hover transition-all duration-150 shadow-subtle hover:shadow-soft active:scale-[0.98]"
                >
                  {primaryCta.text}
                  <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </a>
              )}
              {secondaryCta && (
                <a
                  href={secondaryCta.href}
                  class="inline-flex items-center justify-center h-12 px-6 rounded-md border border-border text-text font-medium hover:bg-surface hover:border-border-hover transition-all duration-150"
                >
                  {secondaryCta.text}
                </a>
              )}
            </div>
          )}
        </div>
      </div>
    </div>
  </section>
)}

{variant === 'antigravity' && (
  <section class="relative overflow-hidden min-h-[80vh]">
    <!-- Antigravity Animation Background -->
    <div class="absolute inset-0 z-0">
      <AntigravityIsland 
        count={antigravityOptions.count || 300}
        color={antigravityOptions.color || '#6366f1'}
        particleShape={antigravityOptions.particleShape || 'capsule'}
        autoAnimate={true}
        magnetRadius={12}
        ringRadius={8}
        waveSpeed={0.3}
        waveAmplitude={1.2}
        lerpSpeed={0.08}
        height="100%"
      />
    </div>
    
    <!-- Content overlay -->
    <div class="container relative z-10">
      <div class="py-24 md:py-32 lg:py-40">
        <div class="max-w-3xl mx-auto text-center">
          {badge && (
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-bg/80 backdrop-blur-sm border border-border text-primary text-small font-medium mb-6 animate-fade-in">
              <span class="w-1.5 h-1.5 rounded-full bg-primary animate-pulse" />
              {badge}
            </div>
          )}
          
          <h1 class="text-display text-text text-balance animate-fade-in animation-delay-100">
            {title}
            {titleHighlight && (
              <span class="text-gradient"> {titleHighlight}</span>
            )}
          </h1>
          
          <p class="mt-6 text-body text-text-secondary max-w-2xl mx-auto text-balance animate-fade-in animation-delay-200">
            {description}
          </p>
          
          {(primaryCta || secondaryCta) && (
            <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mt-10 animate-fade-in animation-delay-300">
              {primaryCta && (
                <a
                  href={primaryCta.href}
                  class="inline-flex items-center justify-center h-12 px-6 rounded-md bg-primary text-primary-foreground font-medium hover:bg-primary-hover transition-all duration-150 shadow-subtle hover:shadow-soft active:scale-[0.98]"
                >
                  {primaryCta.text}
                  <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </a>
              )}
              {secondaryCta && (
                <a
                  href={secondaryCta.href}
                  class="inline-flex items-center justify-center h-12 px-6 rounded-md bg-bg/80 backdrop-blur-sm border border-border text-text font-medium hover:bg-surface hover:border-border-hover transition-all duration-150"
                >
                  {secondaryCta.text}
                </a>
              )}
            </div>
          )}
          
          {stats && stats.length > 0 && (
            <div class="flex flex-wrap items-center justify-center gap-8 md:gap-12 mt-16 pt-8 border-t border-border/50 animate-fade-in animation-delay-400">
              {stats.map((stat) => (
                <div class="text-center">
                  <div class="text-h2 text-text font-bold">{stat.value}</div>
                  <div class="text-body-sm text-muted mt-1">{stat.label}</div>
                </div>
              ))}
            </div>
          )}
        </div>
      </div>
    </div>
    
    <!-- Bottom fade gradient -->
    <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-bg to-transparent z-10 pointer-events-none" />
  </section>
)}
