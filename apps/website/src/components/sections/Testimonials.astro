---
import { testimonials } from '../../config/site';
import SparklesLogoCloud from '../ui/SparklesLogoCloud';

interface Props {
  title?: string;
  description?: string;
  items?: typeof testimonials;
}

const {
  title = 'Teams rely on Kolaybase',
  description = 'What operators and leaders say about rolling out the platform.',
  items = testimonials,
} = Astro.props;
---

<section class="section bg-surface/50">
  <div class="container">
    <!-- Section header -->
    <div class="max-w-2xl mx-auto text-center mb-12">
      <h2 class="text-h2 text-text">{title}</h2>
      <p class="mt-4 text-body text-text-secondary">{description}</p>
    </div>

    <!-- Testimonials grid -->
    <div class="grid md:grid-cols-3 gap-6 max-w-5xl mx-auto">
      {items.map((testimonial, index) => (
        <div
          class="flex flex-col p-6 rounded-lg border border-border bg-bg hover:border-border-hover hover:shadow-soft transition-all duration-200"
          style={`animation-delay: ${index * 100}ms`}
        >
          <!-- Quote icon - inline with content -->
          <svg
            class="w-8 h-8 text-primary/20 mb-4 flex-shrink-0"
            fill="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
          </svg>

          <!-- Content -->
          <p class="text-body text-text-secondary mb-6 flex-grow">
            {testimonial.content}
          </p>

          <!-- Author -->
          <div class="flex items-center gap-3 mt-auto pt-4 border-t border-border/50">
            <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center text-primary font-medium">
              {testimonial.author.charAt(0)}
            </div>
            <div>
              <p class="text-body-sm font-medium text-text">{testimonial.author}</p>
              <p class="text-small text-muted">
                {testimonial.role} at {testimonial.company}
              </p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Social proof with Sparkles Logo Cloud -->
    <div class="mt-16">
      <SparklesLogoCloud
        client:visible
        title="Trusted by experts."
        subtitle="Used by the leaders."
        particleColor="#818cf8"
        particleDensity={150}
        minSize={1}
        maxSize={2.5}
        speed={3}
      />
    </div>
  </div>
</section>
