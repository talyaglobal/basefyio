---
// This is an Astro wrapper for the React ThemeToggle component
// It creates an "island" of interactivity
---

<div id="theme-toggle-container">
  <!-- Placeholder for SSR -->
  <button
    class="inline-flex items-center justify-center gap-2 h-9 px-3 rounded-md text-body-sm text-text-secondary bg-transparent hover:bg-surface border border-transparent hover:border-border transition-all duration-150"
    aria-label="Theme"
  >
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
    </svg>
  </button>
</div>

<script>
  // Theme toggle logic - runs on client
  type Theme = 'light' | 'dark' | 'system';

  function getTheme(): Theme {
    const stored = localStorage.getItem('theme');
    if (stored === 'light' || stored === 'dark' || stored === 'system') {
      return stored;
    }
    return 'system';
  }

  function setTheme(theme: Theme): void {
    localStorage.setItem('theme', theme);
    const root = document.documentElement;

    if (theme === 'system') {
      const systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      root.classList.toggle('dark', systemDark);
    } else {
      root.classList.toggle('dark', theme === 'dark');
    }
  }

  function getIcon(theme: Theme): string {
    switch (theme) {
      case 'light':
        return `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
        </svg>`;
      case 'dark':
        return `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>`;
      case 'system':
        return `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>`;
    }
  }

  function getLabel(theme: Theme): string {
    switch (theme) {
      case 'light': return 'Light';
      case 'dark': return 'Dark';
      case 'system': return 'System';
    }
  }

  function initThemeToggle(): void {
    const container = document.getElementById('theme-toggle-container');
    if (!container) return;

    let currentTheme = getTheme();
    setTheme(currentTheme);

    function updateButton(): void {
      if (!container) return;
      container.innerHTML = `
        <button
          class="inline-flex items-center justify-center gap-2 h-9 px-3 rounded-md text-body-sm text-text-secondary bg-transparent hover:bg-surface border border-transparent hover:border-border transition-all duration-150 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-bg"
          aria-label="Current theme: ${getLabel(currentTheme)}. Click to change."
          title="Theme: ${getLabel(currentTheme)}"
          id="theme-toggle-button"
        >
          ${getIcon(currentTheme)}
        </button>
      `;

      const button = document.getElementById('theme-toggle-button');
      button?.addEventListener('click', () => {
        const themes: Theme[] = ['light', 'dark', 'system'];
        const currentIndex = themes.indexOf(currentTheme);
        const nextIndex = (currentIndex + 1) % themes.length;
        currentTheme = themes[nextIndex];
        setTheme(currentTheme);
        updateButton();
      });
    }

    updateButton();

    // Listen for system theme changes
    window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
      if (currentTheme === 'system') {
        document.documentElement.classList.toggle('dark', e.matches);
      }
    });
  }

  // Initialize on page load
  initThemeToggle();

  // Re-initialize on Astro page transitions
  document.addEventListener('astro:after-swap', initThemeToggle);
</script>
