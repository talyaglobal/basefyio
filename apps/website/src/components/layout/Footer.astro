---
import { siteConfig } from '../../config/site';

const currentYear = new Date().getFullYear();
---

<footer class="bg-surface/50 border-t border-border">
  <div class="container">
    <!-- Main footer content -->
    <div class="py-12 md:py-16">
      <div class="grid grid-cols-2 gap-8 md:grid-cols-4 lg:grid-cols-5">
        <!-- Brand column -->
        <div class="col-span-2 md:col-span-4 lg:col-span-1">
          <a
            href="/"
            class="flex items-center gap-2 text-lg font-semibold text-text transition-opacity hover:opacity-80"
          >
            <img src="/logo.svg" alt="" width="32" height="32" class="h-8 w-8 shrink-0" />
            <span>{siteConfig.name}</span>
          </a>
          <p class="mt-4 max-w-xs text-body-sm text-muted">
            {siteConfig.description}
          </p>

          <!-- Social links -->
          <div class="mt-6 flex items-center gap-3">
            <a
              href={siteConfig.socials.twitter}
              target="_blank"
              rel="noopener noreferrer"
              class="text-muted transition-colors duration-150 hover:text-text"
              aria-label="Twitter"
            >
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                <path
                  d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
                ></path>
              </svg>
            </a>
            <a
              href={siteConfig.socials.github}
              target="_blank"
              rel="noopener noreferrer"
              class="text-muted transition-colors duration-150 hover:text-text"
              aria-label="GitHub"
            >
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                <path
                  fill-rule="evenodd"
                  clip-rule="evenodd"
                  d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
                ></path>
              </svg>
            </a>
            <a
              href={siteConfig.socials.discord}
              target="_blank"
              rel="noopener noreferrer"
              class="text-muted transition-colors duration-150 hover:text-text"
              aria-label="Discord"
            >
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                <path
                  d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"
                ></path>
              </svg>
            </a>
            <a
              href={siteConfig.socials.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              class="text-muted transition-colors duration-150 hover:text-text"
              aria-label="LinkedIn"
            >
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                <path
                  d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                ></path>
              </svg>
            </a>
          </div>
        </div>

        <!-- Product links -->
        <div>
          <h3 class="mb-4 text-body-sm font-semibold text-text">Product</h3>
          <ul class="space-y-3">
            {
              siteConfig.footerLinks.product.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-body-sm text-muted transition-colors duration-150 hover:text-text"
                  >
                    {link.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <!-- Company links -->
        <div>
          <h3 class="mb-4 text-body-sm font-semibold text-text">Company</h3>
          <ul class="space-y-3">
            {
              siteConfig.footerLinks.company.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-body-sm text-muted transition-colors duration-150 hover:text-text"
                  >
                    {link.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <!-- Resources links -->
        <div>
          <h3 class="mb-4 text-body-sm font-semibold text-text">Resources</h3>
          <ul class="space-y-3">
            {
              siteConfig.footerLinks.resources.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-body-sm text-muted transition-colors duration-150 hover:text-text"
                  >
                    {link.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <!-- Legal links -->
        <div>
          <h3 class="mb-4 text-body-sm font-semibold text-text">Legal</h3>
          <ul class="space-y-3">
            {
              siteConfig.footerLinks.legal.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-body-sm text-muted transition-colors duration-150 hover:text-text"
                  >
                    {link.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>

    <!-- Newsletter section -->
    <div class="border-t border-border py-8">
      <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
        <div>
          <h3 class="text-body font-semibold text-text">Newsletter</h3>
          <p class="mt-1 text-body-sm text-muted">
            Product updates and announcements in your inbox.
          </p>
        </div>
        <form class="flex w-full gap-2 md:w-auto" id="newsletter-form">
          <input
            type="email"
            placeholder="Your email"
            required
            class="h-10 flex-1 rounded-md border border-border bg-bg px-3 text-body-sm text-text transition-all duration-150 placeholder:text-muted focus:border-transparent focus:outline-none focus:ring-2 focus:ring-primary md:w-64"
          />
          <button
            type="submit"
            class="h-10 rounded-md bg-primary px-4 text-body-sm font-medium text-primary-foreground transition-colors duration-150 hover:bg-primary-hover"
          >
            Subscribe
          </button>
        </form>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-border py-6">
      <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
        <p class="text-small text-muted">
          © {currentYear}
          {siteConfig.name}. All rights reserved.
        </p>
        <div class="flex flex-wrap items-center gap-4">
          <a
            href={siteConfig.adminPanelUrl}
            class="text-small text-muted transition-colors duration-150 hover:text-text"
            rel="noopener noreferrer"
          >
            Admin sign-in
          </a>
          <a
            href="/legal/privacy"
            class="text-small text-muted transition-colors duration-150 hover:text-text"
          >
            Privacy
          </a>
          <a
            href="/legal/terms"
            class="text-small text-muted transition-colors duration-150 hover:text-text"
          >
            Terms
          </a>
          <a
            href="/sitemap-index.xml"
            class="text-small text-muted transition-colors duration-150 hover:text-text"
          >
            Sitemap
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>

<script>
  const form = document.getElementById('newsletter-form');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    // Handle newsletter subscription
    alert('Thanks — you are on the list.');
    (e.target as HTMLFormElement).reset();
  });
</script>
