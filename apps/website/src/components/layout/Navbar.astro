---
import { siteConfig } from '../../config/site';
import ThemeToggleIsland from './ThemeToggleIsland.astro';

interface Props {
  transparent?: boolean;
}

const { transparent = false } = Astro.props;
const currentPath = Astro.url.pathname;
---

<header
  class:list={[
    'fixed left-0 right-0 top-0 z-50',
    'transition-all duration-200',
    transparent ? 'bg-transparent' : 'bg-bg/80 border-b border-border backdrop-blur-lg',
  ]}
  id="navbar"
>
  <nav class="container flex h-16 items-center justify-between">
    <!-- Logo -->
    <a
      href="/"
      class="flex items-center gap-2 text-lg font-semibold text-text transition-opacity hover:opacity-80"
    >
      <img src="/logo.svg" alt="" width="32" height="32" class="h-8 w-8 shrink-0" />
      <span>{siteConfig.name}</span>
    </a>

    <!-- Desktop Navigation -->
    <div class="hidden items-center gap-1 md:flex">
      {
        siteConfig.navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'rounded-md px-3 py-2 text-body-sm font-medium transition-colors duration-150',
              currentPath === link.href || currentPath.startsWith(link.href + '/')
                ? 'bg-surface text-text'
                : 'text-text-secondary hover:bg-surface hover:text-text',
            ]}
          >
            {link.label}
          </a>
        ))
      }
    </div>

    <!-- Right side actions -->
    <div class="flex items-center gap-3">
      <ThemeToggleIsland />

      <a
        href="/contact"
        class="hidden h-9 items-center justify-center rounded-md bg-primary px-4 text-body-sm font-medium text-primary-foreground transition-colors duration-150 hover:bg-primary-hover sm:inline-flex"
      >
        Get started
      </a>

      <!-- Mobile menu button -->
      <button
        type="button"
        class="inline-flex h-9 w-9 items-center justify-center rounded-md text-text-secondary transition-colors duration-150 hover:bg-surface hover:text-text md:hidden"
        aria-label="Open menu"
        id="mobile-menu-button"
      >
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile Navigation -->
  <div class="hidden md:hidden" id="mobile-menu">
    <div class="container border-t border-border py-4">
      <div class="flex flex-col gap-1">
        {
          siteConfig.navLinks.map((link) => (
            <a
              href={link.href}
              class:list={[
                'rounded-md px-3 py-2 text-body-sm font-medium transition-colors duration-150',
                currentPath === link.href || currentPath.startsWith(link.href + '/')
                  ? 'bg-surface text-text'
                  : 'text-text-secondary hover:bg-surface hover:text-text',
              ]}
            >
              {link.label}
            </a>
          ))
        }
        <a
          href="/contact"
          class="mt-2 inline-flex h-10 items-center justify-center rounded-md bg-primary px-4 text-body-sm font-medium text-primary-foreground transition-colors duration-150 hover:bg-primary-hover"
        >
          Get started
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  // Mobile menu toggle
  const menuButton = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');

  menuButton?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });

  // Close mobile menu on link click
  mobileMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
    });
  });

  // Navbar scroll effect
  const navbar = document.getElementById('navbar');
  let _lastScroll = 0;

  window.addEventListener('scroll', () => {
    const currentScroll = window.scrollY;

    if (currentScroll > 50) {
      navbar?.classList.remove('bg-transparent');
      navbar?.classList.add('bg-bg/80', 'backdrop-blur-lg', 'border-b', 'border-border');
    } else if (navbar?.dataset.transparent === 'true') {
      navbar?.classList.add('bg-transparent');
      navbar?.classList.remove('bg-bg/80', 'backdrop-blur-lg', 'border-b', 'border-border');
    }

    _lastScroll = currentScroll;
  });
</script>
