---
import CTA from '../components/sections/CTA.astro';
import Hero from '../components/sections/Hero.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const team = [
  {
    name: 'Alex Chen',
    role: 'Founder & CEO',
    bio: 'Previously led design at Linear. Passionate about creating beautiful, functional products.',
    avatar: 'AC',
  },
  {
    name: 'Sarah Kim',
    role: 'Head of Engineering',
    bio: 'Former senior engineer at Vercel. Loves building performant web experiences.',
    avatar: 'SK',
  },
  {
    name: 'Marcus Johnson',
    role: 'Lead Designer',
    bio: 'Design systems enthusiast. Previously at Figma working on component libraries.',
    avatar: 'MJ',
  },
  {
    name: 'Emily Rodriguez',
    role: 'Developer Advocate',
    bio: 'Open source contributor and educator. Helps developers build better products.',
    avatar: 'ER',
  },
];

const values = [
  {
    title: 'Quality First',
    description: 'We believe in shipping polished, well-crafted products. Every detail matters.',
    icon: '✨',
  },
  {
    title: 'Developer Experience',
    description: 'Tools should be a joy to use. We obsess over making development feel effortless.',
    icon: '💻',
  },
  {
    title: 'Accessibility',
    description: 'The web should be for everyone. We build with inclusivity at the core.',
    icon: '♿',
  },
  {
    title: 'Developer First',
    description: 'Built by developers, for developers. We prioritize clean code and great DX.',
    icon: '🚀',
  },
];

// Demo milestones - customize with your own company story
const milestones = [
  { year: '2023', title: 'Founded', description: 'Anti-Gravity was born from a desire to make beautiful web design accessible to everyone.' },
  { year: '2023', title: 'First Release', description: 'Launched v1.0 with core components and a comprehensive design system.' },
  { year: '2024', title: 'Growing Community', description: 'Expanded the component library and introduced enterprise licensing.' },
  { year: '2025', title: 'Continuous Updates', description: 'Regular updates with new features, improvements, and customer-driven enhancements.' },
];
---

<BaseLayout
  title="About"
  description="Learn about the team and mission behind Anti-Gravity. We're building the future of web design."
>
  <!-- Hero -->
  <Hero
    variant="default"
    badge="About Us"
    title="Building the future of"
    titleHighlight="web design"
    description="We're a small team of designers and developers passionate about creating beautiful, accessible, and performant web experiences."
  />

  <!-- Mission Section -->
  <section class="section border-t border-border">
    <div class="container">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div>
          <h2 class="text-h2 text-text">Our Mission</h2>
          <p class="mt-4 text-body text-text-secondary">
            We believe that great design should be accessible to everyone. Too often, beautiful websites 
            require expensive designers or complex tools. We're changing that.
          </p>
          <p class="mt-4 text-body text-text-secondary">
            Anti-Gravity provides the building blocks for stunning websites without the complexity. 
            Whether you're a solo developer or a large team, our tools help you ship faster while 
            maintaining the highest quality standards.
          </p>
          <p class="mt-4 text-body text-text-secondary">
            Our goal is simple: make it easy for anyone to create websites that look and feel 
            like they were designed by a world-class team.
          </p>
        </div>
        <div class="relative">
          <div class="absolute -inset-4 bg-gradient-to-r from-primary/10 to-primary/5 rounded-2xl blur-2xl" />
          <div class="relative aspect-square bg-surface border border-border rounded-2xl flex items-center justify-center">
            <svg
              class="w-32 h-32 text-primary"
              viewBox="0 0 32 32"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
            >
              <rect width="32" height="32" rx="8" fill="currentColor" />
              <path
                d="M16 6L26 26H6L16 6Z"
                fill="white"
                fill-opacity="0.9"
              />
            </svg>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Values Section -->
  <section class="section bg-surface/50">
    <div class="container">
      <div class="text-center mb-12">
        <h2 class="text-h2 text-text">Our Values</h2>
        <p class="mt-4 text-body text-text-secondary max-w-2xl mx-auto">
          These principles guide everything we do, from product decisions to how we work together.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {values.map((value) => (
          <div class="p-6 rounded-lg border border-border bg-bg hover:border-border-hover hover:shadow-soft transition-all duration-200">
            <div class="text-3xl mb-4">{value.icon}</div>
            <h3 class="text-h5 text-text mb-2">{value.title}</h3>
            <p class="text-body-sm text-muted">{value.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Team Section -->
  <section class="section">
    <div class="container">
      <div class="text-center mb-12">
        <h2 class="text-h2 text-text">Meet the Team</h2>
        <p class="mt-4 text-body text-text-secondary max-w-2xl mx-auto">
          A small but mighty team dedicated to building the best tools for web developers.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 max-w-5xl mx-auto">
        {team.map((member) => (
          <div class="text-center p-6 rounded-lg border border-border bg-bg hover:border-border-hover hover:shadow-soft transition-all duration-200">
            <div class="w-20 h-20 rounded-full bg-primary-muted flex items-center justify-center text-primary text-h3 font-bold mx-auto mb-4">
              {member.avatar}
            </div>
            <h3 class="text-h5 text-text">{member.name}</h3>
            <p class="text-body-sm text-primary mt-1">{member.role}</p>
            <p class="text-small text-muted mt-3">{member.bio}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Timeline Section -->
  <section class="section bg-surface/50">
    <div class="container">
      <div class="text-center mb-12">
        <h2 class="text-h2 text-text">Our Journey</h2>
        <p class="mt-4 text-body text-text-secondary max-w-2xl mx-auto">
          From idea to reality, here's how Anti-Gravity came to be.
        </p>
      </div>

      <div class="max-w-3xl mx-auto">
        <div class="relative">
          <!-- Timeline line -->
          <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-px bg-border md:-translate-x-px" />

          <!-- Timeline items -->
          <div class="space-y-8">
            {milestones.map((milestone, index) => (
              <div class={`relative flex items-start gap-6 ${index % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'}`}>
                <div class={`flex-1 ${index % 2 === 0 ? 'md:text-right' : 'md:text-left'} hidden md:block`}>
                  <div class="p-4 rounded-lg border border-border bg-bg">
                    <span class="text-small text-primary font-medium">{milestone.year}</span>
                    <h3 class="text-h5 text-text mt-1">{milestone.title}</h3>
                    <p class="text-body-sm text-muted mt-2">{milestone.description}</p>
                  </div>
                </div>
                
                <!-- Dot -->
                <div class="relative z-10 w-8 h-8 rounded-full bg-primary flex items-center justify-center shrink-0">
                  <div class="w-3 h-3 rounded-full bg-white" />
                </div>
                
                <div class="flex-1 md:hidden">
                  <div class="p-4 rounded-lg border border-border bg-bg">
                    <span class="text-small text-primary font-medium">{milestone.year}</span>
                    <h3 class="text-h5 text-text mt-1">{milestone.title}</h3>
                    <p class="text-body-sm text-muted mt-2">{milestone.description}</p>
                  </div>
                </div>
                
                <div class="flex-1 hidden md:block" />
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTA
    variant="centered"
    title="Want to join us?"
    description="We're always looking for talented people to join our team. Check out our open positions."
    primaryCta={{
      text: 'View Open Positions',
      href: '/careers',
    }}
    secondaryCta={{
      text: 'Contact Us',
      href: '/contact',
    }}
  />
</BaseLayout>
