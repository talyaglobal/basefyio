---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// Get all docs
const allDocs = await getCollection('docs', ({ data }) => {
  return data.draft !== true;
});

// Sort by order
const sortedDocs = allDocs.sort((a, b) => a.data.order - b.data.order);

// Group by section
const sections = sortedDocs.reduce((acc, doc) => {
  const section = doc.data.section || 'General';
  if (!acc[section]) {
    acc[section] = [];
  }
  acc[section].push(doc);
  return acc;
}, {} as Record<string, typeof sortedDocs>);

const sectionOrder = ['Getting Started', 'Customization', 'Components', 'General'];
const orderedSections = sectionOrder.filter((s) => sections[s]);
---

<BaseLayout
  title="Documentation"
  description="Learn how to use Anti-Gravity theme with our comprehensive documentation."
>
  <div class="min-h-screen">
    <div class="container py-12">
      <div class="grid lg:grid-cols-4 gap-12">
        <!-- Sidebar -->
        <aside class="lg:col-span-1">
          <div class="sticky top-24">
            <h2 class="text-h5 text-text mb-4">Documentation</h2>
            <nav class="space-y-6">
              {orderedSections.map((sectionName) => (
                <div>
                  <h3 class="text-small font-medium text-muted uppercase tracking-wider mb-2">
                    {sectionName}
                  </h3>
                  <ul class="space-y-1">
                    {sections[sectionName].map((doc) => (
                      <li>
                        <a
                          href={`/docs/${doc.slug}`}
                          class="block px-3 py-2 rounded-md text-body-sm text-text-secondary hover:text-text hover:bg-surface transition-colors duration-150"
                        >
                          {doc.data.title}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </nav>

            <!-- Quick links -->
            <div class="mt-8 pt-8 border-t border-border">
              <h3 class="text-small font-medium text-muted uppercase tracking-wider mb-2">
                Resources
              </h3>
              <ul class="space-y-1">
                <li>
                  <a
                    href="https://github.com/antigravity"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-center gap-2 px-3 py-2 rounded-md text-body-sm text-text-secondary hover:text-text hover:bg-surface transition-colors duration-150"
                  >
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                      <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
                    </svg>
                    GitHub
                  </a>
                </li>
                <li>
                  <a
                    href="/changelog"
                    class="flex items-center gap-2 px-3 py-2 rounded-md text-body-sm text-text-secondary hover:text-text hover:bg-surface transition-colors duration-150"
                  >
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                    </svg>
                    Changelog
                  </a>
                </li>
              </ul>
            </div>
          </div>
        </aside>

        <!-- Main content -->
        <main class="lg:col-span-3">
          <!-- Header -->
          <div class="mb-12">
            <h1 class="text-h1 text-text mb-4">Documentation</h1>
            <p class="text-body text-text-secondary max-w-2xl">
              Everything you need to know about Anti-Gravity. From installation to customization, 
              find guides and references for all features.
            </p>
          </div>

          <!-- Quick start -->
          <div class="mb-12 p-6 rounded-xl border border-primary bg-primary-muted">
            <h2 class="text-h4 text-text mb-2">Quick Start</h2>
            <p class="text-body-sm text-text-secondary mb-4">
              Get up and running with Anti-Gravity in minutes.
            </p>
            <pre class="bg-bg rounded-lg p-4 overflow-x-auto text-body-sm font-mono text-text mb-4"><code>git clone https://github.com/antigravity/theme.git my-project
cd my-project
npm install
npm run dev</code></pre>
            <a
              href="/docs/introduction"
              class="inline-flex items-center text-body-sm text-primary font-medium hover:text-primary-hover transition-colors"
            >
              Read the full guide
              <svg class="ml-1 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>

          <!-- Sections grid -->
          <div class="grid md:grid-cols-2 gap-6">
            {orderedSections.map((sectionName) => (
              <div class="p-6 rounded-xl border border-border bg-bg hover:border-border-hover transition-colors duration-200">
                <h3 class="text-h5 text-text mb-2">{sectionName}</h3>
                <ul class="space-y-2">
                  {sections[sectionName].map((doc) => (
                    <li>
                      <a
                        href={`/docs/${doc.slug}`}
                        class="flex items-center justify-between text-body-sm text-text-secondary hover:text-text transition-colors"
                      >
                        <span>{doc.data.title}</span>
                        <svg class="w-4 h-4 opacity-0 group-hover:opacity-100 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                        </svg>
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>

          <!-- Help section -->
          <div class="mt-12 p-6 rounded-xl border border-border bg-surface/50">
            <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
              <div>
                <h3 class="text-h5 text-text mb-1">Need help?</h3>
                <p class="text-body-sm text-muted">
                  Can't find what you're looking for? We're here to help.
                </p>
              </div>
              <div class="flex gap-3">
                <a
                  href="https://discord.gg/antigravity"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center justify-center h-10 px-4 rounded-md border border-border text-body-sm text-text font-medium hover:bg-bg hover:border-border-hover transition-all duration-150"
                >
                  Join Discord
                </a>
                <a
                  href="/contact"
                  class="inline-flex items-center justify-center h-10 px-4 rounded-md bg-primary text-primary-foreground text-body-sm font-medium hover:bg-primary-hover transition-colors duration-150"
                >
                  Contact Support
                </a>
              </div>
            </div>
          </div>
        </main>
      </div>
    </div>
  </div>
</BaseLayout>
