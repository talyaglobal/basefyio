---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const docs = await getCollection('docs');
  return docs.map((doc) => ({
    params: { slug: doc.slug },
    props: { doc },
  }));
}

interface Props {
  doc: CollectionEntry<'docs'>;
}

const { doc } = Astro.props;
const { Content } = await doc.render();

// Get all docs for sidebar
const allDocs = await getCollection('docs', ({ data }) => data.draft !== true);
const sortedDocs = allDocs.sort((a, b) => a.data.order - b.data.order);

// Group by section
const sections = sortedDocs.reduce((acc, d) => {
  const section = d.data.section || 'General';
  if (!acc[section]) {
    acc[section] = [];
  }
  acc[section].push(d);
  return acc;
}, {} as Record<string, typeof sortedDocs>);

const sectionOrder = ['Getting Started', 'Customization', 'Components', 'General'];
const orderedSections = sectionOrder.filter((s) => sections[s]);

// Get prev/next docs
const currentIndex = sortedDocs.findIndex((d) => d.slug === doc.slug);
const prevDoc = currentIndex > 0 ? sortedDocs[currentIndex - 1] : null;
const nextDoc = currentIndex < sortedDocs.length - 1 ? sortedDocs[currentIndex + 1] : null;
---

<BaseLayout
  title={doc.data.title}
  description={doc.data.description}
>
  <div class="min-h-screen">
    <div class="container py-12">
      <div class="grid lg:grid-cols-4 gap-12">
        <!-- Sidebar -->
        <aside class="lg:col-span-1 hidden lg:block">
          <div class="sticky top-24">
            <h2 class="text-h5 text-text mb-4">Documentation</h2>
            <nav class="space-y-6">
              {orderedSections.map((sectionName) => (
                <div>
                  <h3 class="text-small font-medium text-muted uppercase tracking-wider mb-2">
                    {sectionName}
                  </h3>
                  <ul class="space-y-1">
                    {sections[sectionName].map((d) => (
                      <li>
                        <a
                          href={`/docs/${d.slug}`}
                          class:list={[
                            'block px-3 py-2 rounded-md text-body-sm transition-colors duration-150',
                            d.slug === doc.slug
                              ? 'bg-primary-muted text-primary font-medium'
                              : 'text-text-secondary hover:text-text hover:bg-surface',
                          ]}
                        >
                          {d.data.title}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </nav>

            <!-- Quick links -->
            <div class="mt-8 pt-8 border-t border-border">
              <h3 class="text-small font-medium text-muted uppercase tracking-wider mb-2">
                Resources
              </h3>
              <ul class="space-y-1">
                <li>
                  <a
                    href="https://github.com/antigravity"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-center gap-2 px-3 py-2 rounded-md text-body-sm text-text-secondary hover:text-text hover:bg-surface transition-colors duration-150"
                  >
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                      <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
                    </svg>
                    GitHub
                  </a>
                </li>
                <li>
                  <a
                    href="/changelog"
                    class="flex items-center gap-2 px-3 py-2 rounded-md text-body-sm text-text-secondary hover:text-text hover:bg-surface transition-colors duration-150"
                  >
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                    </svg>
                    Changelog
                  </a>
                </li>
              </ul>
            </div>
          </div>
        </aside>

        <!-- Main content -->
        <main class="lg:col-span-3">
          <!-- Mobile nav -->
          <div class="lg:hidden mb-8">
            <a
              href="/docs"
              class="inline-flex items-center text-body-sm text-muted hover:text-text transition-colors"
            >
              <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
              </svg>
              All Docs
            </a>
          </div>

          <!-- Breadcrumb -->
          <nav class="mb-6">
            <ol class="flex items-center gap-2 text-body-sm">
              <li>
                <a href="/docs" class="text-muted hover:text-text transition-colors">
                  Docs
                </a>
              </li>
              <li class="text-muted">/</li>
              {doc.data.section && (
                <>
                  <li class="text-muted">{doc.data.section}</li>
                  <li class="text-muted">/</li>
                </>
              )}
              <li class="text-text font-medium">{doc.data.title}</li>
            </ol>
          </nav>

          <!-- Header -->
          <header class="mb-8 pb-8 border-b border-border">
            <h1 class="text-h1 text-text mb-2">{doc.data.title}</h1>
            <p class="text-body text-text-secondary">{doc.data.description}</p>
          </header>

          <!-- Content -->
          <div class="prose max-w-none">
            <Content />
          </div>

          <!-- Prev/Next navigation -->
          <nav class="mt-12 pt-8 border-t border-border">
            <div class="flex items-center justify-between">
              {prevDoc ? (
                <a
                  href={`/docs/${prevDoc.slug}`}
                  class="group flex items-center gap-2 text-body-sm text-text-secondary hover:text-text transition-colors"
                >
                  <svg class="w-4 h-4 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                  </svg>
                  <span>
                    <span class="block text-tiny text-muted">Previous</span>
                    <span class="font-medium text-text">{prevDoc.data.title}</span>
                  </span>
                </a>
              ) : (
                <div />
              )}
              
              {nextDoc ? (
                <a
                  href={`/docs/${nextDoc.slug}`}
                  class="group flex items-center gap-2 text-body-sm text-text-secondary hover:text-text transition-colors text-right"
                >
                  <span>
                    <span class="block text-tiny text-muted">Next</span>
                    <span class="font-medium text-text">{nextDoc.data.title}</span>
                  </span>
                  <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                  </svg>
                </a>
              ) : (
                <div />
              )}
            </div>
          </nav>

          <!-- Edit on GitHub -->
          <div class="mt-8 pt-8 border-t border-border">
            <a
              href={`https://github.com/antigravity/theme/edit/main/src/content/docs/${doc.slug}.mdx`}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-body-sm text-muted hover:text-text transition-colors"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
              </svg>
              Edit this page on GitHub
            </a>
          </div>
        </main>
      </div>
    </div>
  </div>
</BaseLayout>
