---
import CTA from '../components/sections/CTA.astro';
import FeaturesSection from '../components/sections/Features.astro';
import Hero from '../components/sections/Hero.astro';
import { features } from '../config/site';
import BaseLayout from '../layouts/BaseLayout.astro';

// Extended features for the features page (available for future use)
const _extendedFeatures = [
  ...features,
  {
    id: 'components',
    title: 'Component Library',
    description:
      'A comprehensive set of pre-built components including buttons, cards, forms, modals, and more.',
    icon: 'Code',
  },
  {
    id: 'mdx',
    title: 'MDX Support',
    description:
      'Write content with MDX for powerful documentation and blog posts with interactive components.',
    icon: 'Code',
  },
  {
    id: 'animations',
    title: 'Smooth Animations',
    description:
      'Subtle, performant animations that enhance the user experience without being distracting.',
    icon: 'Zap',
  },
  {
    id: 'integrations',
    title: 'Easy Integrations',
    description:
      'Seamlessly integrate with your favorite tools and services. Analytics, CMS, and more.',
    icon: 'Settings',
  },
];
---

<BaseLayout
  title="Features"
  description="Explore all the features that make Anti-Gravity the perfect choice for your next project."
>
  <!-- Hero -->
  <Hero
    variant="default"
    badge="Features"
    title="Everything you need to build"
    titleHighlight="amazing websites"
    description="Anti-Gravity comes packed with features designed to help you ship faster. From a comprehensive component library to built-in SEO optimization."
    primaryCta={{
      text: 'Get Started',
      href: '/contact',
    }}
    secondaryCta={{
      text: 'View Pricing',
      href: '/pricing',
    }}
  />

  <!-- Main Features -->
  <FeaturesSection
    title="Core Features"
    description="The essential features that power every Anti-Gravity site."
    items={features}
    columns={4}
  />

  <!-- Detailed Feature Sections -->
  <section class="section border-t border-border">
    <div class="container">
      <!-- Performance -->
      <div class="mb-24 grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
        <div>
          <div
            class="mb-4 inline-flex items-center gap-2 rounded-full bg-primary-muted px-3 py-1 text-small font-medium text-primary"
          >
            Performance
          </div>
          <h2 class="text-h2 text-text">Lightning fast by default</h2>
          <p class="mt-4 text-body text-text-secondary">
            Built on Astro's islands architecture, Anti-Gravity ships zero JavaScript by default.
            Interactive components are hydrated only when needed, resulting in blazing fast page
            loads.
          </p>
          <ul class="mt-6 space-y-3">
            <li class="flex items-start gap-3 text-body-sm text-text-secondary">
              <svg
                class="mt-0.5 h-5 w-5 shrink-0 text-success"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"></path>
              </svg>
              Zero JavaScript by default
            </li>
            <li class="flex items-start gap-3 text-body-sm text-text-secondary">
              <svg
                class="mt-0.5 h-5 w-5 shrink-0 text-success"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"></path>
              </svg>
              Optimized images with Astro Assets
            </li>
            <li class="flex items-start gap-3 text-body-sm text-text-secondary">
              <svg
                class="mt-0.5 h-5 w-5 shrink-0 text-success"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"></path>
              </svg>
              90+ Lighthouse scores
            </li>
          </ul>
        </div>
        <div class="relative">
          <div
            class="from-primary/10 to-primary/5 absolute -inset-4 rounded-2xl bg-gradient-to-r blur-2xl"
          >
          </div>
          <div class="relative rounded-xl border border-border bg-surface p-6">
            <div class="mb-4 flex items-center gap-4">
              <div class="flex items-center gap-1">
                <div class="bg-danger/50 h-3 w-3 rounded-full"></div>
                <div class="bg-warning/50 h-3 w-3 rounded-full"></div>
                <div class="bg-success/50 h-3 w-3 rounded-full"></div>
              </div>
              <span class="text-small text-muted">Lighthouse Report (Example)</span>
            </div>
            <div class="grid grid-cols-4 gap-4">
              {
                [
                  { label: 'Performance', score: 98 },
                  { label: 'Accessibility', score: 100 },
                  { label: 'Best Practices', score: 100 },
                  { label: 'SEO', score: 100 },
                ].map((item) => (
                  <div class="text-center">
                    <div class="relative mx-auto mb-2 h-16 w-16">
                      <svg class="h-16 w-16 -rotate-90 transform">
                        <circle
                          cx="32"
                          cy="32"
                          r="28"
                          stroke="currentColor"
                          stroke-width="4"
                          fill="none"
                          class="text-surface-2"
                        />
                        <circle
                          cx="32"
                          cy="32"
                          r="28"
                          stroke="currentColor"
                          stroke-width="4"
                          fill="none"
                          stroke-dasharray={`${item.score * 1.76} 176`}
                          class="text-success"
                        />
                      </svg>
                      <span class="absolute inset-0 flex items-center justify-center text-body-sm font-bold text-text">
                        {item.score}
                      </span>
                    </div>
                    <span class="text-tiny text-muted">{item.label}</span>
                  </div>
                ))
              }
            </div>
          </div>
        </div>
      </div>

      <!-- Design System -->
      <div class="mb-24 grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
        <div class="order-2 lg:order-1">
          <div class="space-y-4 rounded-xl border border-border bg-surface p-6">
            <div class="flex gap-2">
              <div class="h-8 w-8 rounded bg-primary"></div>
              <div class="h-8 w-8 rounded bg-primary-hover"></div>
              <div class="h-8 w-8 rounded bg-primary-muted"></div>
            </div>
            <div class="flex gap-2">
              <div class="h-8 w-8 rounded bg-success"></div>
              <div class="h-8 w-8 rounded bg-warning"></div>
              <div class="h-8 w-8 rounded bg-danger"></div>
            </div>
            <div class="space-y-2">
              <div class="h-4 w-3/4 rounded bg-text"></div>
              <div class="h-3 w-1/2 rounded bg-muted"></div>
            </div>
            <div class="flex gap-2">
              <button class="h-8 rounded-md bg-primary px-3 text-small text-primary-foreground"
                >Button</button
              >
              <button class="h-8 rounded-md border border-border px-3 text-small text-text"
                >Secondary</button
              >
            </div>
          </div>
        </div>
        <div class="order-1 lg:order-2">
          <div
            class="mb-4 inline-flex items-center gap-2 rounded-full bg-primary-muted px-3 py-1 text-small font-medium text-primary"
          >
            Design System
          </div>
          <h2 class="text-h2 text-text">Consistent & customizable</h2>
          <p class="mt-4 text-body text-text-secondary">
            A comprehensive design system with CSS variables and Tailwind integration. Easily
            customize colors, typography, spacing, and more to match your brand.
          </p>
          <ul class="mt-6 space-y-3">
            <li class="flex items-start gap-3 text-body-sm text-text-secondary">
              <svg
                class="mt-0.5 h-5 w-5 shrink-0 text-success"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"></path>
              </svg>
              CSS variables for easy theming
            </li>
            <li class="flex items-start gap-3 text-body-sm text-text-secondary">
              <svg
                class="mt-0.5 h-5 w-5 shrink-0 text-success"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"></path>
              </svg>
              Tailwind CSS integration
            </li>
            <li class="flex items-start gap-3 text-body-sm text-text-secondary">
              <svg
                class="mt-0.5 h-5 w-5 shrink-0 text-success"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"></path>
              </svg>
              Light & dark mode support
            </li>
          </ul>
        </div>
      </div>

      <!-- Accessibility -->
      <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
        <div>
          <div
            class="mb-4 inline-flex items-center gap-2 rounded-full bg-primary-muted px-3 py-1 text-small font-medium text-primary"
          >
            Accessibility
          </div>
          <h2 class="text-h2 text-text">Built for everyone</h2>
          <p class="mt-4 text-body text-text-secondary">
            Accessibility is not an afterthought. Every component is built with WCAG guidelines in
            mind, ensuring your site is usable by everyone.
          </p>
          <ul class="mt-6 space-y-3">
            <li class="flex items-start gap-3 text-body-sm text-text-secondary">
              <svg
                class="mt-0.5 h-5 w-5 shrink-0 text-success"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"></path>
              </svg>
              Full keyboard navigation
            </li>
            <li class="flex items-start gap-3 text-body-sm text-text-secondary">
              <svg
                class="mt-0.5 h-5 w-5 shrink-0 text-success"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"></path>
              </svg>
              Screen reader friendly
            </li>
            <li class="flex items-start gap-3 text-body-sm text-text-secondary">
              <svg
                class="mt-0.5 h-5 w-5 shrink-0 text-success"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"></path>
              </svg>
              Reduced motion support
            </li>
            <li class="flex items-start gap-3 text-body-sm text-text-secondary">
              <svg
                class="mt-0.5 h-5 w-5 shrink-0 text-success"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"></path>
              </svg>
              WCAG 2.1 AA compliant
            </li>
          </ul>
        </div>
        <div class="relative">
          <div class="rounded-xl border border-border bg-surface p-6">
            <div class="space-y-4">
              <div
                class="bg-primary-muted/50 flex items-center gap-3 rounded-lg border-2 border-primary p-3"
              >
                <div
                  class="flex h-5 w-5 items-center justify-center rounded border-2 border-primary"
                >
                  <svg
                    class="h-3 w-3 text-primary"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="3"
                      d="M5 13l4 4L19 7"></path>
                  </svg>
                </div>
                <span class="text-body-sm text-text">Focus visible indicator</span>
              </div>
              <div class="flex items-center gap-3 rounded-lg border border-border p-3">
                <div class="h-5 w-5 rounded border border-border"></div>
                <span class="text-body-sm text-text-secondary">Keyboard accessible</span>
              </div>
              <div class="flex items-center gap-3 rounded-lg border border-border p-3">
                <div class="h-5 w-5 rounded border border-border"></div>
                <span class="text-body-sm text-text-secondary">ARIA labels</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTA
    variant="centered"
    title="Ready to build something amazing?"
    description="Get started with Anti-Gravity today and ship your next project faster."
    primaryCta={{
      text: 'Get Started',
      href: '/contact',
    }}
    secondaryCta={{
      text: 'View Documentation',
      href: '/docs',
    }}
  />
</BaseLayout>
