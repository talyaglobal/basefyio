---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/sections/Hero.astro';
import { siteConfig } from '../config/site';
---

<BaseLayout
  title="Contact"
  description="Get in touch with the Anti-Gravity team. We'd love to hear from you."
>
  <!-- Hero -->
  <Hero
    variant="default"
    badge="Contact"
    title="Get in touch"
    description="Have a question or want to work together? We'd love to hear from you. Send us a message and we'll respond as soon as possible."
  />

  <section class="section-sm">
    <div class="container">
      <div class="grid lg:grid-cols-3 gap-12 lg:gap-16">
        <!-- Contact Form -->
        <div class="lg:col-span-2">
          <div class="p-6 md:p-8 rounded-xl border border-border bg-bg">
            <h2 class="text-h4 text-text mb-6">Send us a message</h2>
            
            <form id="contact-form" class="space-y-6">
              <div class="grid md:grid-cols-2 gap-6">
                <div class="space-y-1.5">
                  <label for="firstName" class="block text-body-sm font-medium text-text">
                    First name <span class="text-danger">*</span>
                  </label>
                  <input
                    type="text"
                    id="firstName"
                    name="firstName"
                    required
                    class="w-full h-10 px-3 rounded-md border border-border bg-bg text-body text-text placeholder:text-muted focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all duration-150"
                    placeholder="John"
                  />
                </div>
                <div class="space-y-1.5">
                  <label for="lastName" class="block text-body-sm font-medium text-text">
                    Last name <span class="text-danger">*</span>
                  </label>
                  <input
                    type="text"
                    id="lastName"
                    name="lastName"
                    required
                    class="w-full h-10 px-3 rounded-md border border-border bg-bg text-body text-text placeholder:text-muted focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all duration-150"
                    placeholder="Doe"
                  />
                </div>
              </div>

              <div class="space-y-1.5">
                <label for="email" class="block text-body-sm font-medium text-text">
                  Email <span class="text-danger">*</span>
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="w-full h-10 px-3 rounded-md border border-border bg-bg text-body text-text placeholder:text-muted focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all duration-150"
                  placeholder="john@example.com"
                />
              </div>

              <div class="space-y-1.5">
                <label for="company" class="block text-body-sm font-medium text-text">
                  Company
                </label>
                <input
                  type="text"
                  id="company"
                  name="company"
                  class="w-full h-10 px-3 rounded-md border border-border bg-bg text-body text-text placeholder:text-muted focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all duration-150"
                  placeholder="Acme Inc."
                />
              </div>

              <div class="space-y-1.5">
                <label for="subject" class="block text-body-sm font-medium text-text">
                  Subject <span class="text-danger">*</span>
                </label>
                <select
                  id="subject"
                  name="subject"
                  required
                  class="w-full h-10 px-3 rounded-md border border-border bg-bg text-body text-text focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all duration-150"
                >
                  <option value="">Select a subject</option>
                  <option value="general">General Inquiry</option>
                  <option value="support">Technical Support</option>
                  <option value="sales">Sales Question</option>
                  <option value="enterprise">Enterprise Inquiry</option>
                  <option value="partnership">Partnership Opportunity</option>
                  <option value="other">Other</option>
                </select>
              </div>

              <div class="space-y-1.5">
                <label for="message" class="block text-body-sm font-medium text-text">
                  Message <span class="text-danger">*</span>
                </label>
                <textarea
                  id="message"
                  name="message"
                  required
                  rows="5"
                  class="w-full px-3 py-2 rounded-md border border-border bg-bg text-body text-text placeholder:text-muted focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all duration-150 resize-y"
                  placeholder="Tell us how we can help..."
                ></textarea>
              </div>

              <div class="flex items-start gap-3">
                <input
                  type="checkbox"
                  id="privacy"
                  name="privacy"
                  required
                  class="mt-1 w-4 h-4 rounded border-border text-primary focus:ring-primary focus:ring-offset-bg"
                />
                <label for="privacy" class="text-body-sm text-text-secondary">
                  I agree to the <a href="/legal/privacy" class="text-primary hover:text-primary-hover underline underline-offset-2">Privacy Policy</a> and consent to being contacted about my inquiry.
                </label>
              </div>

              <button
                type="submit"
                class="w-full h-12 px-6 rounded-md bg-primary text-primary-foreground font-medium hover:bg-primary-hover transition-all duration-150 shadow-subtle hover:shadow-soft active:scale-[0.99]"
              >
                Send Message
              </button>
            </form>
          </div>
        </div>

        <!-- Contact Info -->
        <div class="space-y-8">
          <!-- Quick Contact -->
          <div class="p-6 rounded-xl border border-border bg-surface/50">
            <h3 class="text-h5 text-text mb-4">Quick Contact</h3>
            <div class="space-y-4">
              <a
                href={`mailto:${siteConfig.email}`}
                class="flex items-center gap-3 text-body-sm text-text-secondary hover:text-text transition-colors"
              >
                <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                {siteConfig.email}
              </a>
              <div class="flex items-center gap-3 text-body-sm text-text-secondary">
                <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                San Francisco, CA
              </div>
            </div>
          </div>

          <!-- Social Links -->
          <div class="p-6 rounded-xl border border-border bg-surface/50">
            <h3 class="text-h5 text-text mb-4">Follow Us</h3>
            <div class="flex gap-3">
              <a
                href={siteConfig.socials.twitter}
                target="_blank"
                rel="noopener noreferrer"
                class="w-10 h-10 rounded-md border border-border flex items-center justify-center text-muted hover:text-text hover:border-border-hover transition-all duration-150"
                aria-label="Twitter"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
                </svg>
              </a>
              <a
                href={siteConfig.socials.github}
                target="_blank"
                rel="noopener noreferrer"
                class="w-10 h-10 rounded-md border border-border flex items-center justify-center text-muted hover:text-text hover:border-border-hover transition-all duration-150"
                aria-label="GitHub"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
                </svg>
              </a>
              <a
                href={siteConfig.socials.discord}
                target="_blank"
                rel="noopener noreferrer"
                class="w-10 h-10 rounded-md border border-border flex items-center justify-center text-muted hover:text-text hover:border-border-hover transition-all duration-150"
                aria-label="Discord"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z" />
                </svg>
              </a>
              <a
                href={siteConfig.socials.linkedin}
                target="_blank"
                rel="noopener noreferrer"
                class="w-10 h-10 rounded-md border border-border flex items-center justify-center text-muted hover:text-text hover:border-border-hover transition-all duration-150"
                aria-label="LinkedIn"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                </svg>
              </a>
            </div>
          </div>

          <!-- Response Time -->
          <div class="p-6 rounded-xl border border-border bg-surface/50">
            <h3 class="text-h5 text-text mb-4">Response Time</h3>
            <p class="text-body-sm text-text-secondary">
              We typically respond within 24 hours during business days. For urgent matters, 
              please reach out via Discord for faster support.
            </p>
          </div>

          <!-- FAQ Link -->
          <div class="p-6 rounded-xl border border-primary bg-primary-muted">
            <h3 class="text-h5 text-text mb-2">Looking for answers?</h3>
            <p class="text-body-sm text-text-secondary mb-4">
              Check out our FAQ section for quick answers to common questions.
            </p>
            <a
              href="/#faq"
              class="inline-flex items-center text-body-sm text-primary font-medium hover:text-primary-hover transition-colors"
            >
              View FAQ
              <svg class="ml-1 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    
    // Get form data
    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());
    
    // Here you would typically send the data to your backend
    console.log('Form submitted:', data);
    
    // Show success message
    alert('Thank you for your message! We\'ll get back to you soon.');
    form.reset();
  });
</script>
