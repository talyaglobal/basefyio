---
import CTA from '../components/sections/CTA.astro';
import FAQ from '../components/sections/FAQ.astro';
import Hero from '../components/sections/Hero.astro';
import PricingSection from '../components/sections/Pricing.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { faqItems } from '../config/site';

const pricingFaq = [
  {
    question: 'Where do prices come from?',
    answer:
      'The grid calls the public `GET /api/billing/plans` endpoint. Amounts reflect the `plans` records in the product database. USD prices are billed monthly through Stripe unless your contract states otherwise.',
  },
  {
    question: 'What happens after I pick a plan?',
    answer:
      '“Sign up with this plan” sends you to the app signup screen with a `plan` query parameter. After signup, billing or payment steps apply for paid tiers. Stripe customer portal and card updates happen inside the app.',
  },
  {
    question: 'Can I upgrade, downgrade, or cancel?',
    answer:
      'Upgrades mid-period typically use proration—preview it inside billing. Downgrades and cancellations depend on your contract period; the in-app billing page and legal terms are authoritative.',
  },
  ...faqItems.slice(0, 4),
];
---

<BaseLayout
  title="Pricing — Kolaybase plans"
  description="Live plan matrix sourced from the platform API. Compare quotas and jump straight to signup with your chosen tier."
>
  <Hero
    variant="default"
    badge="Pricing"
    title="Clear plans,"
    titleHighlight="live data"
    description="Every row maps to a real plan object. Limits for projects, storage, seats, and API calls are summarized per card. Free and paid tiers share the same signup path—only the downstream billing rules change."
    primaryCta={{
      text: 'Jump to plans',
      href: '#pricing-section',
    }}
    secondaryCta={{
      text: 'Contact sales',
      href: '/contact',
    }}
  />

  <PricingSection
    title="Compare plans"
    description="Numbers refresh from the API each visit. Use the CTA on a card to pre-select that plan during signup."
  />

  <FAQ title="Billing questions" description="Plans, payments, and signup flows." items={pricingFaq} />

  <CTA
    variant="default"
    title="Need a custom quote?"
    description="Volume discounts, enterprise SLAs, or dedicated infrastructure? We will scope it with your technical and procurement teams."
    primaryCta={{
      text: 'Contact form',
      href: '/contact',
    }}
    secondaryCta={{
      text: 'Roadmap',
      href: '/roadmap',
    }}
  />
</BaseLayout>
