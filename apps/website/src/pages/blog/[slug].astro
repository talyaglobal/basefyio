---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await post.render();

const formatDate = (date: Date) => {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
};

// Get related posts (same tags)
const allPosts = await getCollection('blog', ({ data }) => data.draft !== true);
const relatedPosts = allPosts
  .filter((p) => p.slug !== post.slug)
  .filter((p) => p.data.tags.some((tag) => post.data.tags.includes(tag)))
  .slice(0, 3);
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  ogImage={post.data.image?.src}
>
  <article class="section-sm">
    <div class="container">
      <div class="max-w-3xl mx-auto">
        <!-- Back link -->
        <a
          href="/blog"
          class="inline-flex items-center text-body-sm text-muted hover:text-text transition-colors mb-8"
        >
          <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Back to Blog
        </a>

        <!-- Header -->
        <header class="mb-8">
          <!-- Tags -->
          <div class="flex items-center gap-2 mb-4">
            {post.data.tags.map((tag) => (
              <a
                href={`/blog/tag/${tag}`}
                class="inline-flex items-center px-2.5 py-0.5 rounded-full text-tiny font-medium bg-primary-muted text-primary hover:bg-primary/20 transition-colors"
              >
                {tag}
              </a>
            ))}
          </div>

          <!-- Title -->
          <h1 class="text-h1 text-text mb-4">{post.data.title}</h1>

          <!-- Description -->
          <p class="text-body text-text-secondary mb-6">{post.data.description}</p>

          <!-- Meta -->
          <div class="flex items-center gap-4 pb-8 border-b border-border">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-primary-muted flex items-center justify-center text-primary font-medium">
                {post.data.author.name.charAt(0)}
              </div>
              <div>
                <p class="text-body-sm font-medium text-text">{post.data.author.name}</p>
                {post.data.author.role && (
                  <p class="text-small text-muted">{post.data.author.role}</p>
                )}
              </div>
            </div>
            <div class="h-8 w-px bg-border" />
            <div class="text-body-sm text-muted">
              <time datetime={post.data.pubDate.toISOString()}>
                {formatDate(post.data.pubDate)}
              </time>
            </div>
          </div>
        </header>

        <!-- Featured Image -->
        {post.data.image && (
          <div class="mb-12 -mx-4 md:-mx-8 lg:-mx-16">
            <img
              src={post.data.image.src}
              alt={post.data.image.alt}
              class="w-full rounded-xl border border-border"
              loading="eager"
            />
          </div>
        )}

        <!-- Content -->
        <div class="prose max-w-none">
          <Content />
        </div>

        <!-- Share & Tags -->
        <footer class="mt-12 pt-8 border-t border-border">
          <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
            <!-- Tags -->
            <div class="flex items-center gap-2">
              <span class="text-body-sm text-muted">Tags:</span>
              {post.data.tags.map((tag) => (
                <a
                  href={`/blog/tag/${tag}`}
                  class="inline-flex items-center px-2.5 py-0.5 rounded-full text-tiny font-medium bg-surface text-text-secondary hover:bg-surface-2 transition-colors"
                >
                  {tag}
                </a>
              ))}
            </div>

            <!-- Share -->
            <div class="flex items-center gap-2">
              <span class="text-body-sm text-muted">Share:</span>
              <a
                href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.data.title)}&url=${encodeURIComponent(Astro.url.href)}`}
                target="_blank"
                rel="noopener noreferrer"
                class="w-8 h-8 rounded-md border border-border flex items-center justify-center text-muted hover:text-text hover:border-border-hover transition-all duration-150"
                aria-label="Share on Twitter"
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
                </svg>
              </a>
              <a
                href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(Astro.url.href)}`}
                target="_blank"
                rel="noopener noreferrer"
                class="w-8 h-8 rounded-md border border-border flex items-center justify-center text-muted hover:text-text hover:border-border-hover transition-all duration-150"
                aria-label="Share on LinkedIn"
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                </svg>
              </a>
              <button
                class="w-8 h-8 rounded-md border border-border flex items-center justify-center text-muted hover:text-text hover:border-border-hover transition-all duration-150"
                aria-label="Copy link"
                id="copy-link"
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                </svg>
              </button>
            </div>
          </div>
        </footer>

        <!-- Author Bio -->
        <div class="mt-12 p-6 rounded-xl border border-border bg-surface/50">
          <div class="flex items-start gap-4">
            <div class="w-16 h-16 rounded-full bg-primary-muted flex items-center justify-center text-primary text-h4 font-bold shrink-0">
              {post.data.author.name.charAt(0)}
            </div>
            <div>
              <p class="text-body-sm text-muted mb-1">Written by</p>
              <p class="text-h5 text-text">{post.data.author.name}</p>
              {post.data.author.role && (
                <p class="text-body-sm text-primary mt-1">{post.data.author.role}</p>
              )}
              <p class="text-body-sm text-muted mt-2">
                Building the future of web design at Anti-Gravity. Passionate about creating beautiful, accessible experiences.
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Related Posts -->
      {relatedPosts.length > 0 && (
        <div class="max-w-5xl mx-auto mt-16 pt-16 border-t border-border">
          <h2 class="text-h3 text-text mb-8">Related Posts</h2>
          <div class="grid md:grid-cols-3 gap-6">
            {relatedPosts.map((relatedPost) => (
              <a
                href={`/blog/${relatedPost.slug}`}
                class="group p-6 rounded-xl border border-border bg-bg hover:border-border-hover hover:shadow-soft transition-all duration-200"
              >
                <div class="flex items-center gap-2 mb-3">
                  {relatedPost.data.tags.slice(0, 1).map((tag) => (
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-tiny font-medium bg-surface text-muted">
                      {tag}
                    </span>
                  ))}
                </div>
                <h3 class="text-h6 text-text group-hover:text-primary transition-colors mb-2 line-clamp-2">
                  {relatedPost.data.title}
                </h3>
                <p class="text-small text-muted line-clamp-2">
                  {relatedPost.data.description}
                </p>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </article>
</BaseLayout>

<script>
  const copyButton = document.getElementById('copy-link');
  copyButton?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(window.location.href);
      alert('Link copied to clipboard!');
    } catch (err) {
      console.error('Failed to copy:', err);
    }
  });
</script>
