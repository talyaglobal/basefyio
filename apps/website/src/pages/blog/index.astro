---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/sections/Hero.astro';
import { getCollection } from 'astro:content';

// Get all blog posts, sorted by date
const allPosts = await getCollection('blog', ({ data }) => {
  return data.draft !== true;
});

const sortedPosts = allPosts.sort((a, b) => {
  return new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime();
});

const featuredPosts = sortedPosts.filter((post) => post.data.featured);
const recentPosts = sortedPosts.slice(0, 6);

// Get all unique tags
const allTags = [...new Set(sortedPosts.flatMap((post) => post.data.tags))];

const formatDate = (date: Date) => {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
};
---

<BaseLayout
  title="Blog"
  description="Insights, tutorials, and updates from the Anti-Gravity team. Learn about web development, design systems, and more."
>
  <!-- Hero -->
  <Hero
    variant="default"
    badge="Blog"
    title="Insights &"
    titleHighlight="Updates"
    description="Tutorials, best practices, and news from the Anti-Gravity team. Stay up to date with the latest in web development and design."
  />

  <section class="section-sm">
    <div class="container">
      <!-- Featured Posts -->
      {featuredPosts.length > 0 && (
        <div class="mb-16">
          <h2 class="text-h4 text-text mb-6">Featured</h2>
          <div class="grid md:grid-cols-2 gap-6">
            {featuredPosts.slice(0, 2).map((post) => (
              <a
                href={`/blog/${post.slug}`}
                class="group relative overflow-hidden rounded-xl border border-border bg-bg hover:border-border-hover hover:shadow-soft transition-all duration-200"
              >
                {post.data.image && (
                  <div class="aspect-video overflow-hidden">
                    <img
                      src={post.data.image.src}
                      alt={post.data.image.alt}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                      loading="lazy"
                    />
                  </div>
                )}
                <div class="p-6">
                  <div class="flex items-center gap-2 mb-3">
                    {post.data.tags.slice(0, 2).map((tag) => (
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-tiny font-medium bg-primary-muted text-primary">
                        {tag}
                      </span>
                    ))}
                  </div>
                  <h3 class="text-h4 text-text group-hover:text-primary transition-colors mb-2">
                    {post.data.title}
                  </h3>
                  <p class="text-body-sm text-muted line-clamp-2 mb-4">
                    {post.data.description}
                  </p>
                  <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-full bg-surface flex items-center justify-center text-text text-small font-medium">
                      {post.data.author.name.charAt(0)}
                    </div>
                    <div>
                      <p class="text-small font-medium text-text">{post.data.author.name}</p>
                      <p class="text-tiny text-muted">{formatDate(post.data.pubDate)}</p>
                    </div>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}

      <div class="grid lg:grid-cols-4 gap-12">
        <!-- Posts Grid -->
        <div class="lg:col-span-3">
          <h2 class="text-h4 text-text mb-6">All Posts</h2>
          <div class="grid md:grid-cols-2 gap-6">
            {recentPosts.map((post) => (
              <a
                href={`/blog/${post.slug}`}
                class="group p-6 rounded-xl border border-border bg-bg hover:border-border-hover hover:shadow-soft transition-all duration-200"
              >
                <div class="flex items-center gap-2 mb-3">
                  {post.data.tags.slice(0, 2).map((tag) => (
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-tiny font-medium bg-surface text-muted">
                      {tag}
                    </span>
                  ))}
                </div>
                <h3 class="text-h5 text-text group-hover:text-primary transition-colors mb-2">
                  {post.data.title}
                </h3>
                <p class="text-body-sm text-muted line-clamp-2 mb-4">
                  {post.data.description}
                </p>
                <div class="flex items-center justify-between">
                  <div class="flex items-center gap-2">
                    <div class="w-6 h-6 rounded-full bg-surface flex items-center justify-center text-text text-tiny font-medium">
                      {post.data.author.name.charAt(0)}
                    </div>
                    <span class="text-small text-muted">{post.data.author.name}</span>
                  </div>
                  <span class="text-small text-muted">{formatDate(post.data.pubDate)}</span>
                </div>
              </a>
            ))}
          </div>

          {sortedPosts.length > 6 && (
            <div class="mt-8 text-center">
              <button
                class="inline-flex items-center justify-center h-10 px-6 rounded-md border border-border text-body-sm text-text font-medium hover:bg-surface hover:border-border-hover transition-all duration-150"
              >
                Load More Posts
              </button>
            </div>
          )}
        </div>

        <!-- Sidebar -->
        <div class="lg:col-span-1">
          <!-- Tags -->
          <div class="p-6 rounded-xl border border-border bg-surface/50 mb-6">
            <h3 class="text-h6 text-text mb-4">Topics</h3>
            <div class="flex flex-wrap gap-2">
              {allTags.map((tag) => (
                <a
                  href={`/blog/tag/${tag}`}
                  class="inline-flex items-center px-3 py-1.5 rounded-full text-small font-medium bg-bg border border-border text-text-secondary hover:border-border-hover hover:text-text transition-all duration-150"
                >
                  {tag}
                </a>
              ))}
            </div>
          </div>

          <!-- Newsletter -->
          <div class="p-6 rounded-xl border border-primary bg-primary-muted">
            <h3 class="text-h6 text-text mb-2">Subscribe to our newsletter</h3>
            <p class="text-small text-muted mb-4">
              Get the latest posts delivered straight to your inbox.
            </p>
            <form class="space-y-3" id="blog-newsletter">
              <input
                type="email"
                placeholder="Enter your email"
                required
                class="w-full h-10 px-3 rounded-md border border-border bg-bg text-body-sm text-text placeholder:text-muted focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all duration-150"
              />
              <button
                type="submit"
                class="w-full h-10 rounded-md bg-primary text-primary-foreground text-body-sm font-medium hover:bg-primary-hover transition-colors duration-150"
              >
                Subscribe
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('blog-newsletter');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    alert('Thank you for subscribing!');
    (e.target as HTMLFormElement).reset();
  });
</script>
