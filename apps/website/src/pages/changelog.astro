---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/sections/Hero.astro';
import { changelogEntries } from '../config/site';

const getTypeColor = (type: string) => {
  switch (type) {
    case 'feature':
      return 'bg-primary-muted text-primary';
    case 'fix':
      return 'bg-success/10 text-success';
    case 'release':
      return 'bg-warning/10 text-warning';
    default:
      return 'bg-surface text-muted';
  }
};

const getTypeLabel = (type: string) => {
  switch (type) {
    case 'feature':
      return 'Feature';
    case 'fix':
      return 'Bug Fix';
    case 'release':
      return 'Release';
    default:
      return type;
  }
};
---

<BaseLayout
  title="Changelog"
  description="Stay up to date with the latest updates, improvements, and fixes to Anti-Gravity."
>
  <!-- Hero -->
  <Hero
    variant="default"
    badge="Changelog"
    title="What's new in"
    titleHighlight="Anti-Gravity"
    description="Stay up to date with the latest updates, improvements, and bug fixes. We ship new features and improvements regularly."
  />

  <!-- Changelog -->
  <section class="section-sm">
    <div class="container">
      <div class="max-w-3xl mx-auto">
        <!-- Subscribe to updates -->
        <div class="mb-12 p-6 rounded-xl border border-border bg-surface/50">
          <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
            <div>
              <h3 class="text-h5 text-text">Get notified of updates</h3>
              <p class="text-body-sm text-muted mt-1">Subscribe to receive changelog updates in your inbox.</p>
            </div>
            <form class="flex gap-2" id="changelog-subscribe">
              <input
                type="email"
                placeholder="Enter your email"
                required
                class="w-full md:w-48 h-10 px-3 rounded-md border border-border bg-bg text-body-sm text-text placeholder:text-muted focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all duration-150"
              />
              <button
                type="submit"
                class="h-10 px-4 rounded-md bg-primary text-primary-foreground text-body-sm font-medium hover:bg-primary-hover transition-colors duration-150 whitespace-nowrap"
              >
                Subscribe
              </button>
            </form>
          </div>
        </div>

        <!-- Timeline -->
        <div class="relative">
          <!-- Timeline line -->
          <div class="absolute left-4 top-0 bottom-0 w-px bg-border" />

          <!-- Entries -->
          <div class="space-y-12">
            {changelogEntries.map((entry, index) => (
              <article class="relative pl-12">
                <!-- Timeline dot -->
                <div class="absolute left-0 w-8 h-8 rounded-full bg-bg border-2 border-border flex items-center justify-center">
                  <div class="w-2 h-2 rounded-full bg-primary" />
                </div>

                <!-- Content -->
                <div class="p-6 rounded-xl border border-border bg-bg hover:border-border-hover transition-colors duration-200">
                  <!-- Header -->
                  <div class="flex flex-wrap items-center gap-3 mb-4">
                    <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-tiny font-medium ${getTypeColor(entry.type)}`}>
                      {getTypeLabel(entry.type)}
                    </span>
                    <span class="text-body-sm font-mono text-primary">v{entry.version}</span>
                    <span class="text-small text-muted">
                      {new Date(entry.date).toLocaleDateString('en-US', {
                        year: 'numeric',
                        month: 'long',
                        day: 'numeric',
                      })}
                    </span>
                  </div>

                  <!-- Title & Description -->
                  <h2 class="text-h4 text-text mb-2">{entry.title}</h2>
                  <p class="text-body-sm text-text-secondary mb-4">{entry.description}</p>

                  <!-- Changes list -->
                  <ul class="space-y-2">
                    {entry.changes.map((change) => (
                      <li class="flex items-start gap-3 text-body-sm text-text-secondary">
                        <svg class="w-5 h-5 text-success shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                        </svg>
                        {change}
                      </li>
                    ))}
                  </ul>
                </div>
              </article>
            ))}
          </div>
        </div>

        <!-- Load more / Archive link -->
        <div class="mt-12 text-center">
          <p class="text-body-sm text-muted mb-4">
            Looking for older releases?
          </p>
          <a
            href="https://github.com/antigravity/releases"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center text-body-sm text-primary font-medium hover:text-primary-hover transition-colors"
          >
            View all releases on GitHub
            <svg class="ml-1 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('changelog-subscribe');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    alert('Thank you for subscribing to changelog updates!');
    (e.target as HTMLFormElement).reset();
  });
</script>
