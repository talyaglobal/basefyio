# Public site URL (no trailing slash). Used as fallback when request Host is unavailable (e.g. some builds).
# Production example: https://basefyio.com
NEXT_PUBLIC_SITE_URL=http://localhost:3002

# Admin / app portal for CTAs (Sign in, Sign up). Production: https://app.basefyio.com
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Public API base for docs code samples. Production: https://api.basefyio.com
# NEXT_PUBLIC_API_BASE_URL=https://api.basefyio.com

# Optional: Google Search Console HTML tag verification (content value only, not the full tag)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_verification_string

# Google Analytics 4 (gtag). Defaults to G-7Q90HE6Z02 when unset. Set to empty string only to disable.
# Production: do not leave blank — GA "tag not detected" often comes from empty NEXT_PUBLIC_* at build.
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-7Q90HE6Z02
