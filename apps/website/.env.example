# Public site URL (no trailing slash). Used as fallback when request Host is unavailable (e.g. some builds).
# Production example: https://kolaybase.com
NEXT_PUBLIC_SITE_URL=http://localhost:3002

# Admin / app portal for CTAs (Sign in, Sign up). Production: https://app.kolaybase.com
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Public API base for docs code samples. Production: https://api.kolaybase.com
# NEXT_PUBLIC_API_BASE_URL=https://api.kolaybase.com

# Optional: Google Search Console HTML tag verification (content value only, not the full tag)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_verification_string

# Google Analytics 4 (gtag). Defaults to G-9HTNF4CR06 when unset. Set to empty to disable.
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-9HTNF4CR06
