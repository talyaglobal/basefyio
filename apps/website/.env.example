# Kolaybase marketing sitesi — build ve canonical URL’ler için
# Kopyalayın: copy .env.example .env  (PowerShell: Copy-Item .env.example .env)

# Üretim domain’i (sitemap, Open Graph, JSON-LD)
PUBLIC_SITE_URL=https://kolaybase.com

# Yönetim paneli (footer “Yönetim girişi” bağlantısı)
PUBLIC_ADMIN_URL=https://app.kolaybase.com

# Kayıt / uygulama kökü (fiyat kartları “Bu paketle kayıt ol” → /signup?plan=…)
PUBLIC_APP_URL=http://localhost:3000

# Platform API — tarayıcıdan /api/billing/plans çağrısı (CORS gerekir)
PUBLIC_PLATFORM_API_URL=http://localhost:8000
