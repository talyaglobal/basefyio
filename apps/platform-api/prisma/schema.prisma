generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  USER
  ROOT
}

enum ProjectStatus {
  ACTIVE
  PAUSED
  DELETED
}

enum TeamMemberRole {
  OWNER
  MEMBER
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
  INCOMPLETE
}

enum AccountStatus {
  ACTIVE
  FROZEN
  CANCELLED
}

enum InfraStatus {
  PROVISIONING
  ACTIVE
  MIGRATING
  FAILED
  DEPROVISIONING
  STOPPED
}

model User {
  id              String   @id
  firstName       String?  @map("first_name")
  lastName        String?  @map("last_name")
  email           String   @unique
  role            UserRole @default(USER)
  activeTeamId    String?  @map("active_team_id")
  avatarUrl       String?  @map("avatar_url")
  githubUsername  String?  @map("github_username")
  notifySignIn    Boolean  @default(true) @map("notify_sign_in")
  notifySignInNewDevice Boolean @default(false) @map("notify_sign_in_new_device")
  notifyTeamInvite Boolean @default(true) @map("notify_team_invite")
  notifyBrowserPush Boolean @default(false) @map("notify_browser_push")
  lastLoginFingerprint String? @map("last_login_fingerprint")
  lastLoginAt     DateTime? @map("last_login_at")
  createdAt       DateTime @default(now()) @map("created_at")

  activeTeam       Team?             @relation("ActiveTeam", fields: [activeTeamId], references: [id])
  personalTeam     Team?             @relation("PersonalTeam")
  teamMembers      TeamMember[]
  receivedInvites  TeamInvite[]      @relation("ReceivedInvites")
  sentInvites      TeamInvite[]      @relation("SentInvites")
  feedbacks        Feedback[]
  feedbackComments FeedbackComment[]
  feedbackEvents   FeedbackEvent[]

  @@map("users")
}

model RolePermission {
  id                     String   @id @default(uuid())
  role                   UserRole @unique
  canAccessManagement    Boolean  @default(false) @map("can_access_management")
  canManageUsers         Boolean  @default(false) @map("can_manage_users")
  canManageTeams         Boolean  @default(false) @map("can_manage_teams")
  canManagePlans         Boolean  @default(false) @map("can_manage_plans")
  canManageUserPackages  Boolean  @default(false) @map("can_manage_user_packages")
  canModerateFeedback    Boolean  @default(false) @map("can_moderate_feedback")
  canViewAuditLogs       Boolean  @default(false) @map("can_view_audit_logs")
  canViewRootAlerts      Boolean  @default(false) @map("can_view_root_alerts")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  @@map("role_permissions")
}

model Team {
  id                String        @id @default(uuid())
  name              String
  slug              String        @unique
  personalForUserId String?       @unique @map("personal_for_user_id")
  accountStatus     AccountStatus @default(ACTIVE) @map("account_status")
  createdAt         DateTime      @default(now()) @map("created_at")

  // GitHub OAuth (team-level)
  githubOAuthToken  String?  @map("github_oauth_token")
  githubOAuthLogin  String?  @map("github_oauth_login")
  githubOAuthAvatar String?  @map("github_oauth_avatar")

  // Vercel OAuth (team-level)
  vercelOAuthToken  String?  @map("vercel_oauth_token")
  vercelOAuthTeamId String?  @map("vercel_oauth_team_id")
  vercelOAuthUser   String?  @map("vercel_oauth_user")

  personalForUser   User?        @relation("PersonalTeam", fields: [personalForUserId], references: [id])
  activeForUsers    User[]       @relation("ActiveTeam")
  members           TeamMember[]
  invites           TeamInvite[]
  projects          Project[]
  folders           ProjectFolder[]
  tags              ProjectTag[]
  subscription      Subscription?
  invoices          Invoice[]
  usage             TeamUsage?
  infrastructure    TeamInfrastructure?
  billingAccount    BillingAccount?

  @@map("teams")
}

model TeamMember {
  id        String         @id @default(uuid())
  teamId    String         @map("team_id")
  userId    String         @map("user_id")
  role      TeamMemberRole @default(MEMBER)
  createdAt DateTime       @default(now()) @map("created_at")

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@map("team_members")
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model TeamInvite {
  id            String       @id @default(uuid())
  teamId        String       @map("team_id")
  invitedUserId String?      @map("invited_user_id")
  invitedEmail  String?      @map("invited_email")
  invitedById   String       @map("invited_by_id")
  status        InviteStatus @default(PENDING)
  createdAt     DateTime     @default(now()) @map("created_at")

  team        Team  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  invitedUser User? @relation("ReceivedInvites", fields: [invitedUserId], references: [id], onDelete: Cascade)
  invitedBy   User  @relation("SentInvites", fields: [invitedById], references: [id], onDelete: Cascade)

  @@unique([teamId, invitedUserId])
  @@unique([teamId, invitedEmail])
  @@map("team_invites")
}

model Project {
  id            String        @id @default(uuid())
  name          String
  slug          String        @unique
  description   String?
  dbName        String        @map("db_name")
  dbHost        String        @default("localhost") @map("db_host")
  dbPort        Int           @default(5432) @map("db_port")
  dbUser        String        @map("db_user")
  dbPassword    String        @map("db_password")
  keycloakRealm String        @map("keycloak_realm")
  anonKey       String        @map("anon_key")
  serviceKey    String        @map("service_key")
  teamId        String        @map("team_id")
  createdBy     String?       @map("created_by")
  importSource  String        @default("MANUAL") @map("import_source")
  /// Last successful Supabase import summary (tables, auth, storage, warnings).
  supabaseImportLog Json?     @map("supabase_import_log")
  status        ProjectStatus @default(ACTIVE)
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  /// When the project was moved to trash; used for 24h retention (not `updatedAt`).
  deletedAt     DateTime?     @map("deleted_at")
  /// When RLS roles (anon / authenticated / service_role) and auth.* helpers
  /// were installed into the project DB. Null = not yet bootstrapped.
  rlsBootstrappedAt DateTime? @map("rls_bootstrapped_at")

  // Folder
  folderId      String?  @map("folder_id")

  // GitHub Integration
  githubToken   String? @map("github_token")
  githubOwner   String? @map("github_owner")
  githubRepo    String? @map("github_repo")
  githubBranch  String? @default("main") @map("github_branch")

  // Vercel Integration
  vercelToken     String? @map("vercel_token")
  vercelProjectId String? @map("vercel_project_id")
  vercelTeamId    String? @map("vercel_team_id")

  team         Team          @relation(fields: [teamId], references: [id])
  folder       ProjectFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  tags          ProjectTagAssignment[]
  sqlAuditLogs  SqlAuditLog[]
  authConfig    ProjectAuthConfig?
  activityLogs    ProjectActivityLog[]
  infrastructure  ProjectInfrastructure?

  @@map("projects")
}

model ProjectActivityLog {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  userId    String?  @map("user_id")
  kind      String   @db.VarChar(80)
  title     String   @db.VarChar(512)
  detail    String?  @db.Text
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt(sort: Desc)])
  @@map("project_activity_logs")
}

model ProjectFolder {
  id        String   @id @default(uuid())
  name      String
  color     String   @default("#6366f1")
  teamId    String   @map("team_id")
  createdAt DateTime @default(now()) @map("created_at")

  team     Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  projects Project[]

  @@map("project_folders")
}

model ProjectTag {
  id        String   @id @default(uuid())
  name      String
  color     String   @default("#8b5cf6")
  teamId    String   @map("team_id")
  createdAt DateTime @default(now()) @map("created_at")

  team        Team                   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  assignments ProjectTagAssignment[]

  @@unique([teamId, name])
  @@map("project_tags")
}

model ProjectTagAssignment {
  id        String @id @default(uuid())
  projectId String @map("project_id")
  tagId     String @map("tag_id")

  project Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tag     ProjectTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([projectId, tagId])
  @@map("project_tag_assignments")
}

model ProjectAuthConfig {
  id                    String  @id @default(uuid())
  projectId             String  @unique @map("project_id")
  allowSignup           Boolean @default(true) @map("allow_signup")
  requireEmailVerify    Boolean @default(true) @map("require_email_verify")
  minPasswordLength     Int     @default(6) @map("min_password_length")
  tokenExpirySeconds    Int     @default(1800) @map("token_expiry_seconds")
  emailProvider         String? @map("email_provider")
  smtpHost              String? @map("smtp_host")
  smtpPort              Int?    @map("smtp_port")
  smtpUser              String? @map("smtp_user")
  smtpPass              String? @map("smtp_pass")
  senderEmail           String? @map("sender_email")
  senderName            String? @map("sender_name")
  resendApiKey          String? @map("resend_api_key")
  sendgridApiKey        String? @map("sendgrid_api_key")
  sesAccessKey          String? @map("ses_access_key")
  sesSecretKey          String? @map("ses_secret_key")
  sesRegion             String? @map("ses_region")
  verifyEmailSubject    String? @map("verify_email_subject")
  verifyEmailBody       String? @map("verify_email_body") @db.Text
  resetPasswordSubject  String? @map("reset_password_subject")
  resetPasswordBody     String? @map("reset_password_body") @db.Text
  welcomeSubject        String? @map("welcome_subject")
  welcomeBody           String? @map("welcome_body") @db.Text
  inviteUserSubject     String? @map("invite_user_subject")
  inviteUserBody        String? @map("invite_user_body") @db.Text
  magicLinkSubject      String? @map("magic_link_subject")
  magicLinkBody         String? @map("magic_link_body") @db.Text
  changeEmailSubject    String? @map("change_email_subject")
  changeEmailBody       String? @map("change_email_body") @db.Text
  reauthSubject         String? @map("reauth_subject")
  reauthBody            String? @map("reauth_body") @db.Text
  googleEnabled         Boolean @default(false) @map("google_enabled")
  googleClientId        String? @map("google_client_id")
  googleClientSecret    String? @map("google_client_secret")
  githubEnabled         Boolean @default(false) @map("github_enabled")
  githubClientId        String? @map("github_client_id")
  githubClientSecret    String? @map("github_client_secret")
  microsoftEnabled      Boolean @default(false) @map("microsoft_enabled")
  microsoftClientId     String? @map("microsoft_client_id")
  microsoftClientSecret String? @map("microsoft_client_secret")
  appleEnabled          Boolean @default(false) @map("apple_enabled")
  appleClientId         String? @map("apple_client_id")
  appleClientSecret     String? @map("apple_client_secret")
  gitlabEnabled         Boolean @default(false) @map("gitlab_enabled")
  gitlabClientId        String? @map("gitlab_client_id")
  gitlabClientSecret    String? @map("gitlab_client_secret")
  linkedinEnabled       Boolean @default(false) @map("linkedin_enabled")
  linkedinClientId      String? @map("linkedin_client_id")
  linkedinClientSecret  String? @map("linkedin_client_secret")
  facebookEnabled       Boolean @default(false) @map("facebook_enabled")
  facebookClientId      String? @map("facebook_client_id")
  facebookClientSecret  String? @map("facebook_client_secret")
  twitterEnabled        Boolean @default(false) @map("twitter_enabled")
  twitterClientId       String? @map("twitter_client_id")
  twitterClientSecret   String? @map("twitter_client_secret")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_auth_configs")
}

model SqlAuditLog {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  userId    String   @map("user_id")
  query     String
  rowCount  Int?     @map("row_count")
  duration  Int?
  error     String?
  createdAt DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([userId])
  @@map("sql_audit_logs")
}

enum FeedbackType {
  BUG
  FEATURE
  GENERAL
}

enum FeedbackStatus {
  OPEN
  IN_PROGRESS
  DONE
  CLOSED
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  realm     String?
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email])
  @@index([token])
  @@map("password_reset_tokens")
}

model LoginSecurityState {
  id                String    @id @default(uuid())
  email             String    @unique
  failedAttempts    Int       @default(0) @map("failed_attempts")
  consecutiveFailed Int       @default(0) @map("consecutive_failed")
  lockedUntil       DateTime? @map("locked_until")
  captchaQuestion   String?   @map("captcha_question")
  captchaAnswer     String?   @map("captcha_answer")
  captchaExpiresAt  DateTime? @map("captcha_expires_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@index([email])
  @@map("login_security_states")
}

model Feedback {
  id          String         @id @default(uuid())
  userId      String         @map("user_id")
  email       String
  url         String
  title       String
  description String?
  /// JSON array: { url, mimeType, kind: "image" | "video" }[]
  attachments Json?        @map("attachments")
  type        FeedbackType   @default(GENERAL)
  status      FeedbackStatus @default(OPEN)
  deletedAt   DateTime?      @map("deleted_at")
  createdAt   DateTime       @default(now()) @map("created_at")
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments    FeedbackComment[]
  events      FeedbackEvent[]

  @@index([userId])
  @@index([deletedAt])
  @@map("feedbacks")
}

model FeedbackEvent {
  id        String   @id @default(uuid())
  feedbackId String  @map("feedback_id")
  userId    String   @map("user_id")
  action    String
  detail    String?
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  feedback Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([feedbackId, createdAt])
  @@map("feedback_events")
}

model FeedbackComment {
  id              String   @id @default(uuid())
  feedbackId      String   @map("feedback_id")
  userId          String   @map("user_id")
  comment         String
  attachments     Json?    @map("attachments")
  parentCommentId String?  @map("parent_comment_id")
  createdAt       DateTime @default(now()) @map("created_at")

  feedback      Feedback         @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentComment FeedbackComment? @relation("FeedbackCommentReplies", fields: [parentCommentId], references: [id], onDelete: SetNull)
  replies       FeedbackComment[] @relation("FeedbackCommentReplies")

  @@index([feedbackId, createdAt])
  @@index([feedbackId, parentCommentId, createdAt])
  @@map("feedback_comments")
}

// ── Billing ──────────────────────────────────────────────

model Plan {
  id                String   @id @default(uuid())
  name              String   @unique
  displayName       String   @map("display_name")
  maxProjects       Int?     @map("max_projects")
  maxStorageBytes   BigInt?  @map("max_storage_bytes")
  maxTeamMembers    Int?     @map("max_team_members")
  maxDbSizeBytes    BigInt?  @map("max_db_size_bytes")
  maxApiRequests    Int?     @map("max_api_requests")
  maxBandwidthBytes BigInt?  @map("max_bandwidth_bytes")
  maxMau            Int?     @map("max_mau")
  dedicatedDb       Boolean  @default(false) @map("dedicated_db")
  dedicatedStorage  Boolean  @default(false) @map("dedicated_storage")
  dbMemoryMb        Int      @default(0) @map("db_memory_mb")
  dbCpuMillis       Int      @default(0) @map("db_cpu_millis")
  priceMonthly      Int      @default(0) @map("price_monthly")
  stripePriceId     String?  @map("stripe_price_id")
  stripeProductId   String?  @map("stripe_product_id")
  isPublic          Boolean  @default(true) @map("is_public")
  features          Json?
  createdAt         DateTime @default(now()) @map("created_at")

  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id                   String             @id @default(uuid())
  teamId               String             @unique @map("team_id")
  planId               String             @map("plan_id")
  status               SubscriptionStatus @default(ACTIVE)
  stripeCustomerId     String?            @map("stripe_customer_id")
  stripeSubscriptionId String?            @map("stripe_subscription_id")
  currentPeriodStart   DateTime?          @map("current_period_start")
  currentPeriodEnd     DateTime?          @map("current_period_end")
  nextBillingDate      DateTime?          @map("next_billing_date")
  billingDayOfMonth    Int?               @map("billing_day_of_month")
  retryCount           Int                @default(0) @map("retry_count")
  lastRetryDate        DateTime?          @map("last_retry_date")
  firstFailureAt       DateTime?          @map("first_failure_at")
  /// When a plan upgrade payment fails, target plan and amount are stored until paid or window lapses.
  pendingPlanId        String?            @map("pending_plan_id")
  pendingAmountDue     Int?               @map("pending_amount_due")
  cancelAtPeriodEnd    Boolean            @default(false) @map("cancel_at_period_end")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  plan Plan @relation(fields: [planId], references: [id])

  @@map("subscriptions")
}

model Invoice {
  id              String    @id @default(uuid())
  teamId          String    @map("team_id")
  stripeInvoiceId String?   @unique @map("stripe_invoice_id")
  amountDue       Int       @map("amount_due")
  amountPaid      Int       @default(0) @map("amount_paid")
  currency        String    @default("usd")
  status          String
  invoiceUrl      String?   @map("invoice_url")
  invoicePdf      String?   @map("invoice_pdf")
  periodStart     DateTime? @map("period_start")
  periodEnd       DateTime? @map("period_end")
  retryCount      Int       @default(0) @map("retry_count")
  lastRetryDate   DateTime? @map("last_retry_date")
  createdAt       DateTime  @default(now()) @map("created_at")

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@map("invoices")
}

model BillingAccount {
  id           String   @id @default(uuid())
  teamId       String   @unique @map("team_id")
  companyName  String?  @map("company_name")
  taxId        String?  @map("tax_id")
  vatNumber    String?  @map("vat_number")
  addressLine1 String?  @map("address_line1")
  addressLine2 String?  @map("address_line2")
  city         String?
  state        String?
  postalCode   String?  @map("postal_code")
  country      String?
  billingEmail String?  @map("billing_email")
  phone        String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@map("billing_accounts")
}

// ── Usage Tracking ───────────────────────────────────────

model TeamUsage {
  id               String   @id @default(uuid())
  teamId           String   @unique @map("team_id")
  projectCount     Int      @default(0) @map("project_count")
  storageBytes     BigInt   @default(0) @map("storage_bytes")
  memberCount      Int      @default(0) @map("member_count")
  dbSizeBytes      BigInt   @default(0) @map("db_size_bytes")
  apiRequestsMonth Int      @default(0) @map("api_requests_month")
  bandwidthMonth   BigInt   @default(0) @map("bandwidth_month")
  mauCount         Int      @default(0) @map("mau_count")
  periodStart      DateTime @default(now()) @map("period_start")
  lastCalculatedAt DateTime @default(now()) @map("last_calculated_at")

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@map("team_usage")
}

model UsageRecord {
  id          String   @id @default(uuid())
  teamId      String   @map("team_id")
  projectId   String?  @map("project_id")
  metric      String
  value       BigInt
  recordedAt  DateTime @default(now()) @map("recorded_at")
  periodStart DateTime @map("period_start")
  periodEnd   DateTime @map("period_end")

  @@index([teamId, metric, recordedAt])
  @@index([projectId, metric, recordedAt])
  @@map("usage_records")
}

// ── Dedicated Infrastructure ─────────────────────────────

model ProjectInfrastructure {
  id              String      @id @default(uuid())
  projectId       String      @unique @map("project_id")
  pgContainerName String?     @map("pg_container_name")
  pgContainerHost String?     @map("pg_container_host")
  pgContainerPort Int?        @map("pg_container_port")
  pgAdminUser     String?     @map("pg_admin_user")
  pgAdminPassword String?     @map("pg_admin_password")
  pgMemoryMb      Int         @default(1024) @map("pg_memory_mb")
  pgCpuMillis     Int         @default(1000) @map("pg_cpu_millis")
  pgVolumeId      String?     @map("pg_volume_id")
  status          InfraStatus @default(PROVISIONING)
  provisionedAt   DateTime?   @map("provisioned_at")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_infrastructure")
}

model TeamInfrastructure {
  id                 String      @id @default(uuid())
  teamId             String      @unique @map("team_id")
  minioContainerName String?     @map("minio_container_name")
  minioContainerHost String?     @map("minio_container_host")
  minioContainerPort Int?        @map("minio_container_port")
  minioAccessKey     String?     @map("minio_access_key")
  minioSecretKey     String?     @map("minio_secret_key")
  minioVolumeId      String?     @map("minio_volume_id")
  status             InfraStatus @default(PROVISIONING)
  provisionedAt      DateTime?   @map("provisioned_at")
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@map("team_infrastructure")
}

model AuditLog {
  id           String   @id @default(uuid())
  traceId      String   @map("trace_id")
  actorUserId  String   @map("actor_user_id")
  actorRole    String   @map("actor_role")
  action       String
  resourceType String   @map("resource_type")
  resourceId   String?  @map("resource_id")
  severity     String
  success      Boolean  @default(true)
  beforeJson   Json?    @map("before_json")
  afterJson    Json?    @map("after_json")
  metadataJson Json?    @map("metadata_json")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([actorUserId, createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
  @@index([traceId])
  @@map("audit_logs")
}

model RootAlert {
  id                String   @id @default(uuid())
  kind              String
  severity          String
  title             String
  message           String
  relatedAuditLogId String?  @map("related_audit_log_id")
  isRead            Boolean  @default(false) @map("is_read")
  createdAt         DateTime @default(now()) @map("created_at")

  @@index([isRead, createdAt(sort: Desc)])
  @@index([kind, createdAt(sort: Desc)])
  @@map("root_alerts")
}
