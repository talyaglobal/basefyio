# Database Configuration (PostgreSQL)
DATABASE_URL=postgresql://username:password@host:5432/database

# Database Provider & Connection Settings
DB_PROVIDER=neon
DB_REGION=us-east-1
DB_MAX_CONNECTIONS=100
DB_BACKUP_RETENTION=7
DB_ENABLE_REPLICAS=false
DB_ENABLE_PITR=false

# Connection Pool Settings
DB_POOL_MAX=20
DB_POOL_MIN=5
DB_POOL_IDLE_TIMEOUT=300000
DB_POOL_CONNECTION_TIMEOUT=30000
DB_POOL_RETRY_ATTEMPTS=3
DB_ENABLE_READ_REPLICAS=false
# DB_READ_REPLICA_URLS=replica1_url,replica2_url

# Authentication & Security - generate secure random strings for production
JWT_SECRET=your_super_secret_jwt_key_here_change_me_in_production
REFRESH_SECRET=your_refresh_secret_key_here_change_me_in_production
MAGIC_SECRET=your_magic_link_secret_here_change_me_in_production

# Master key for secrets encryption (strongly recommended)
KOLAYBASE_MASTER_KEY=your_master_key_for_encryption_here_change_me_in_production

# Application URLs
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_APP_NAME=Kolaybase

# Storage Configuration
STORAGE_SECRET=your_storage_secret_here_or_uses_jwt_secret
STORAGE_BASE_URL=http://localhost:3000

# OAuth Providers (optional - only needed if using OAuth)
# GITHUB_CLIENT_ID=your_github_oauth_client_id
# GITHUB_CLIENT_SECRET=your_github_oauth_client_secret
# GOOGLE_CLIENT_ID=your_google_oauth_client_id
# GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# Environment
NODE_ENV=development