# ── Database ──────────────────────────────────────────────
POSTGRES_USER=basefyio
POSTGRES_PASSWORD=basefyio_secret
POSTGRES_PORT=5433
POSTGRES_PUBLIC_HOST=localhost
POSTGRES_PUBLIC_PORT=5433

# Platform database connection string used by Prisma (platform-api).
# Must match the POSTGRES_* values above. Prisma reads env("DATABASE_URL").
DATABASE_URL=postgresql://basefyio:basefyio_secret@localhost:5433/basefyio?schema=public

# ── Auth Provider (Keycloak) ──────────────────────────────
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_PORT=8080
KEYCLOAK_PUBLIC_URL=http://localhost:8080

# ── Object Storage (MinIO) ────────────────────────────────
MINIO_ROOT_USER=basefyio
MINIO_ROOT_PASSWORD=basefyio_secret
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_PUBLIC_ENDPOINT=localhost
MINIO_PUBLIC_PORT=9000

# ── Redis ─────────────────────────────────────────────────
REDIS_PORT=6379
# Connection string used by the platform-api Redis client + BullMQ queue.
REDIS_URL=redis://localhost:6379

# ── Connection Pooler (PgBouncer) ─────────────────────────
PGBOUNCER_PORT=6432
PGBOUNCER_EXTERNAL_HOST=localhost
# Admin-console credentials (used to RELOAD the pooler). Change these in any
# real deployment — the defaults below are for local development only.
PGBOUNCER_ADMIN_USER=pgbouncer_admin
PGBOUNCER_ADMIN_PASSWORD=pgbouncer_admin_pass

# ── Applications ──────────────────────────────────────────
PLATFORM_API_PORT=4000
ADMIN_UI_PORT=3000
APP_URL=http://localhost:3000
PUBLIC_API_URL=http://localhost:4000

# ── Data Engine (optional, disabled by default) ───────────
# DATA_ENGINE_PROVIDER=couchdb
# NOSQL_CONNSTR=http://couchdb:5984
# NOSQL_USERNAME=basefyio
# NOSQL_PASSWORD=basefyio_secret

# ── Email (optional) ──────────────────────────────────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user
# SMTP_PASS=password
# EMAIL_FROM=basefyio <noreply@example.com>

# ── OAuth Providers (optional) ────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
