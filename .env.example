# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_USER=kolaybase
POSTGRES_PASSWORD=kolaybase_secret
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=kolaybase

# ── Keycloak ───────────────────────────────────────────────
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_ADMIN_CLIENT_ID=admin-cli

# ── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── MinIO ──────────────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ROOT_USER=kolaybase
MINIO_ROOT_PASSWORD=kolaybase_secret
MINIO_USE_SSL=false

# ── PgBouncer ─────────────────────────────────────────────
PGBOUNCER_PORT=6432
PGBOUNCER_EXTERNAL_HOST=localhost
PGBOUNCER_EXTERNAL_PORT=6432

# ── Platform API ───────────────────────────────────────────
PLATFORM_API_PORT=4000
DATABASE_URL=postgresql://kolaybase:kolaybase_secret@localhost:5432/kolaybase
PUBLIC_API_URL=http://localhost:4000

# ── App URL (used in emails for links like password reset) ─
# Local: http://localhost:3000
# Production: https://app.yourdomain.com
APP_URL=http://localhost:3000

# ── Admin UI ───────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8080

# ── Team-level GitHub OAuth (create at github.com/settings/developers) ──
# Callback URL: http://localhost:4000/api/team-integrations/github/callback
TEAM_GITHUB_CLIENT_ID=
TEAM_GITHUB_CLIENT_SECRET=

# ── Team-level Vercel OAuth (create at vercel.com/account/oauth-apps) ──
# Callback URL: http://localhost:4000/api/team-integrations/vercel/callback
TEAM_VERCEL_CLIENT_ID=
TEAM_VERCEL_CLIENT_SECRET=