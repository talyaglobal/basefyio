# ─────────────────────────────────────────────────────────────────────────────
# basefyio — environment configuration
# Copy to `.env` and fill in. NEVER commit a real .env file.
# Values shown are safe local-dev defaults; change ALL secrets for production.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core URLs ───────────────────────────────────────────────────────────────
# Public base domain used to derive service hostnames in production.
DOMAIN=example.com
# Where the admin dashboard is served.
APP_URL=http://localhost:3000
# Public base URL of the platform API (used in emails, OAuth callbacks, SDK).
PUBLIC_API_URL=http://localhost:4000

# ── PostgreSQL (shared control-plane database) ──────────────────────────────
POSTGRES_USER=basefyio
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=basefyio
# Full connection string used by Prisma (must match the values above).
DATABASE_URL=postgresql://basefyio:change-me-strong-password@postgres:5432/basefyio

# ── Keycloak (identity provider) ────────────────────────────────────────────
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_PUBLIC_URL=http://localhost:8080
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-strong-password
KEYCLOAK_ADMIN_CLIENT_ID=admin-cli
# OAuth client id of the control-plane app inside the master realm.
PLATFORM_KEYCLOAK_CLIENT_ID=basefyio-platform

# ── MinIO (object storage) ──────────────────────────────────────────────────
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ROOT_USER=basefyio
MINIO_ROOT_PASSWORD=change-me-strong-password

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Docker provisioning (dedicated per-project infra) ───────────────────────
DOCKER_SOCKET_PATH=/var/run/docker.sock
DOCKER_NETWORK=basefyio_default
# Reverse-DNS prefix for metadata labels on managed Docker resources.
DOCKER_LABEL_PREFIX=com.basefyio

# ── PgBouncer (connection pooling) ──────────────────────────────────────────
PGBOUNCER_ADMIN_PASSWORD=change-me-strong-password

# ── Email (Resend) — optional ───────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=basefyio <noreply@example.com>
RESEND_REPLY_TO=support@example.com
# Comma-separated recipients for new-feedback notifications.
FEEDBACK_NOTIFY_EMAILS=support@example.com
BILLING_SUMMARY_RECIPIENT=support@example.com

# ── Billing (Stripe) — optional ─────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── Accounting (QuickBooks Online) — optional ───────────────────────────────
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REDIRECT_URI=http://localhost:4000/api/admin/quickbooks/callback
QUICKBOOKS_ENVIRONMENT=sandbox
# AES key used to encrypt stored QuickBooks tokens (set a strong random value).
QB_ENCRYPTION_KEY=
