# Vercel ignore file
# Files and directories to exclude from deployment

# Environment files
.env
.env.local
.env.*.local

# Development files
.vscode/
.idea/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs (will be regenerated)
.next/
dist/
build/
out/

# Dependencies (installed on Vercel)
node_modules/

# Database scripts (not needed in production)
scripts/setup-db.js
scripts/init-db.sql

# Documentation
docs/
*.md
!README.md

# Test files
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx
__tests__/
coverage/

# Development tools
.eslintcache
.stylelintcache
tsconfig.tsbuildinfo

