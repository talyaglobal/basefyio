# ── Domain ────────────────────────────────────────────────
DOMAIN=kolaybase.com
ACME_EMAIL=admin@kolaybase.com

# ── GHCR ──────────────────────────────────────────────────
# GitHub Container Registry owner (org or username)
GHCR_OWNER=kolaybase

# ── Traefik Dashboard ────────────────────────────────────
# Generate with: htpasswd -nB admin
TRAEFIK_DASHBOARD_AUTH=admin:$$2y$$05$$...hashed_password...

# ── PostgreSQL ────────────────────────────────────────────
POSTGRES_USER=kolaybase
POSTGRES_PASSWORD=CHANGE_ME_strong_random_password

# ── Keycloak ──────────────────────────────────────────────
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_strong_random_password

# ── MinIO ─────────────────────────────────────────────────
MINIO_ROOT_USER=kolaybase
MINIO_ROOT_PASSWORD=CHANGE_ME_strong_random_password
