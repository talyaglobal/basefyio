# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# local env files (keep example files, ignore actual env files)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Keep these example files in the repository
!.env.example
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Database files
*.db
*.sqlite
*.sqlite3
/database/backups/
/temp-backups/
/migrations/temp/

# Application logs
logs/
*.log
/tmp/
/temp/

# Package manager locks (keep package-lock.json, remove others)
# yarn.lock  
pnpm-lock.yaml

# ESLint cache
.eslintcache

# Upload directories
/uploads/
/storage/
/temp-files/

# Certificate and key files
*.key
*.crt
*.pem
*.p12

# Backup files
*.backup
*.bak
*.old
*.orig

# Security sensitive files
secrets.json
service-account.json
*.p8

# Build artifacts
dist/

# Runtime data
pids/
*.pid
*.seed
*.pid.lock
