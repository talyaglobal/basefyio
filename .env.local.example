# .env.local - Production overrides (this file should not be committed)
# Copy this to .env.local and fill in your production values

# Production Database
DATABASE_URL=postgresql://prod_user:prod_password@prod_host:5432/prod_database

# Production Security Keys - Generate strong random keys for production
JWT_SECRET=your_production_jwt_secret_256_bit_key
REFRESH_SECRET=your_production_refresh_secret_256_bit_key
MAGIC_SECRET=your_production_magic_link_secret_256_bit_key
KOLAYBASE_MASTER_KEY=your_production_master_encryption_key_256_bit

# Production URLs
NEXT_PUBLIC_BASE_URL=https://your-domain.com
NEXT_PUBLIC_API_URL=https://your-domain.com/api
STORAGE_BASE_URL=https://your-domain.com

# Production OAuth (if using)
GITHUB_CLIENT_ID=your_production_github_client_id
GITHUB_CLIENT_SECRET=your_production_github_client_secret
GOOGLE_CLIENT_ID=your_production_google_client_id
GOOGLE_CLIENT_SECRET=your_production_google_client_secret

# Production Environment
NODE_ENV=production

# Production Database Settings (optional overrides)
DB_MAX_CONNECTIONS=200
DB_POOL_MAX=50
DB_ENABLE_REPLICAS=true
DB_READ_REPLICA_URLS=replica1_url,replica2_url