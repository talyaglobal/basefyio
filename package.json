{
  "name": "basefyio",
  "version": "0.0.0",
  "private": true,
  "description": "The open-source, self-hosted backend platform. PostgreSQL-first.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/myfyio/basefyio",
  "repository": {
    "type": "git",
    "url": "https://github.com/myfyio/basefyio.git"
  },
  "bugs": {
    "url": "https://github.com/myfyio/basefyio/issues"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "multer@>=2.0.0-alpha.1 <2.2.0": "^2.2.0",
      "dompurify@<=3.4.10": "^3.4.11",
      "lodash@<=4.17.22": "^4.17.23",
      "postcss@<8.5.10": "^8.5.10",
      "qs@>=6.11.1 <=6.15.1": "^6.15.2"
    }
  }
}
